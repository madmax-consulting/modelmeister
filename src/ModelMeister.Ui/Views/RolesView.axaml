<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ModelMeister.Ui.ViewModels"
             xmlns:svc="using:ModelMeister.Ui.Services"
             xmlns:c="using:ModelMeister.Ui.Controls"
             xmlns:conv="using:ModelMeister.Ui.Converters"
             x:Class="ModelMeister.Ui.Views.RolesView"
             x:DataType="vm:RolesViewModel"
             x:Name="PageRoot">

  <UserControl.KeyBindings>
    <KeyBinding Gesture="Delete" Command="{Binding DeleteSelectedRolesCommand}" />
    <KeyBinding Gesture="Escape" Command="{Binding Selection.ClearCommand}" />
    <KeyBinding Gesture="Ctrl+A" Command="{Binding Selection.SelectAllVisibleCommand}" />
  </UserControl.KeyBindings>

  <c:PageShell Eyebrow="ROLES"
               Subtitle="Inspect, export, and provision roles + their permission bindings — export/import via the icons above"
               Status="{Binding Status}"
               IsBusy="{Binding Busy}">
    <c:PageShell.Actions>
      <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
        <Button Classes="ghost icon" ToolTip.Tip="New role"
                Command="{Binding AddRoleCommand}">
          <Path Data="{DynamicResource IcoPlus}" Width="13" Height="13" Stretch="Uniform"
                Stroke="{DynamicResource TextSec}" StrokeThickness="1.8"
                StrokeJoin="Round" StrokeLineCap="Round" Fill="Transparent" />
        </Button>
        <Button Classes="ghost icon" ToolTip.Tip="Add or remove a permission on selected roles"
                Command="{Binding BulkSetPermissionCommand}"
                IsVisible="{Binding Selection.HasSelection}">
          <Path Data="{DynamicResource IcoShield}" Width="14" Height="14" Stretch="Uniform"
                Stroke="{DynamicResource TextSec}" StrokeThickness="1.6"
                StrokeJoin="Round" StrokeLineCap="Round" Fill="Transparent" />
        </Button>
        <Button Classes="ghost icon danger" ToolTip.Tip="Delete selected roles"
                Command="{Binding DeleteSelectedRolesCommand}"
                IsVisible="{Binding Selection.HasSelection}">
          <Path Data="{DynamicResource IcoTrash}" Width="13" Height="13" Stretch="Uniform"
                Stroke="{DynamicResource Danger}" StrokeThickness="1.6"
                StrokeJoin="Round" StrokeLineCap="Round" Fill="Transparent" />
        </Button>
        <Border Width="1" Margin="4,4" Background="{DynamicResource BorderFaint}" />
        <c:ExcelMenu DataContext="{Binding}" />
        <c:PageActions DataContext="{Binding}" />
      </StackPanel>
    </c:PageShell.Actions>

    <Border Classes="card flush" Padding="0">
      <DockPanel LastChildFill="True">
        <c:GridToolbar DockPanel.Dock="Top" Margin="8,8,8,4" TargetGrid="{Binding #RolesGrid}" />
        <Grid>
          <!-- Empty state: when no roles (typically because we're not connected) -->
          <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                      Spacing="6" Margin="0,40"
                      IsVisible="{Binding Roles.Count, Converter={x:Static svc:Eq.IsZero}}">
            <TextBlock Text="No roles to show" FontWeight="SemiBold" FontSize="14" HorizontalAlignment="Center" />
            <TextBlock Text="Connect to an environment to see its roles." Classes="subtle" HorizontalAlignment="Center" />
          </StackPanel>
          <DataGrid Name="RolesGrid"
                    ItemsSource="{Binding Roles}" IsReadOnly="True"
                    AutoGenerateColumns="False" GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                    BorderThickness="0" svc:GridSelectionBehavior.Selection="{Binding Selection}">
            <DataGrid.ContextMenu>
              <ContextMenu>
                <MenuItem Header="Edit"
                          Command="{Binding EditRoleCommand}"
                          CommandParameter="{Binding #RolesGrid.SelectedItem}" />
                <Separator />
                <MenuItem Header="Copy name"
                          Command="{Binding CopyNameCommand}"
                          CommandParameter="{Binding #RolesGrid.SelectedItem}" />
                <MenuItem Header="Copy description"
                          Command="{Binding CopyDescriptionCommand}"
                          CommandParameter="{Binding #RolesGrid.SelectedItem}" />
                <MenuItem Header="Copy permissions"
                          Command="{Binding CopyPermissionsCommand}"
                          CommandParameter="{Binding #RolesGrid.SelectedItem}" />
                <Separator />
                <MenuItem Header="Delete"
                          Command="{Binding DeleteRoleCommand}"
                          CommandParameter="{Binding #RolesGrid.SelectedItem}" />
                <MenuItem Header="Delete selected"
                          Command="{Binding DeleteSelectedRolesCommand}"
                          IsEnabled="{Binding Selection.HasSelection}" />
              </ContextMenu>
            </DataGrid.ContextMenu>
            <DataGrid.Columns>
              <DataGridTemplateColumn Width="40" CanUserResize="False" CanUserReorder="False" CanUserSort="False"
                                      CellTemplate="{StaticResource RowSelectCell}">
                <DataGridTemplateColumn.Header>
                  <CheckBox IsChecked="{Binding #PageRoot.((vm:RolesViewModel)DataContext).Selection.AllSelected, Mode=TwoWay}"
                            ToolTip.Tip="Select all" />
                </DataGridTemplateColumn.Header>
              </DataGridTemplateColumn>
              <DataGridTextColumn Binding="{Binding Name}" Width="240" MinWidth="140">
                <DataGridTextColumn.Header><c:FilterableHeader Title="Name" Path="Name" /></DataGridTextColumn.Header>
              </DataGridTextColumn>
              <DataGridTextColumn Binding="{Binding Description}" Width="2*" MinWidth="160">
                <DataGridTextColumn.Header><c:FilterableHeader Title="Description" Path="Description" /></DataGridTextColumn.Header>
              </DataGridTextColumn>
              <!-- Permissions column: comma-joined for read; copy via context menu. -->
              <DataGridTextColumn Binding="{Binding Permissions, Converter={x:Static conv:JoinStringsConverter.Instance}}" Width="3*" MinWidth="160">
                <DataGridTextColumn.Header><c:FilterableHeader Title="Permissions" Path="Permissions" /></DataGridTextColumn.Header>
              </DataGridTextColumn>
              <DataGridTemplateColumn Header="" Width="92">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate x:DataType="vm:RoleListRow">
                    <StackPanel Orientation="Horizontal" Spacing="3" Margin="4,0">
                      <Button Classes="ghost icon" Padding="6" ToolTip.Tip="Edit"
                              Command="{Binding $parent[DataGrid].((vm:RolesViewModel)DataContext).EditRoleCommand}"
                              CommandParameter="{Binding}">
                        <Path Data="{DynamicResource IcoEdit}" Width="12" Height="12" Stretch="Uniform"
                              Stroke="{DynamicResource TextSec}" StrokeThickness="1.6" Fill="Transparent" />
                      </Button>
                      <Button Classes="ghost icon danger" Padding="6" ToolTip.Tip="Delete"
                              Command="{Binding $parent[DataGrid].((vm:RolesViewModel)DataContext).DeleteRoleCommand}"
                              CommandParameter="{Binding}">
                        <Path Data="{DynamicResource IcoTrash}" Width="12" Height="12" Stretch="Uniform"
                              Stroke="{DynamicResource Danger}" StrokeThickness="1.6" Fill="Transparent" />
                      </Button>
                    </StackPanel>
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>
            </DataGrid.Columns>
          </DataGrid>
        </Grid>
      </DockPanel>
    </Border>

  </c:PageShell>
</UserControl>
