<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ModelMeister.Ui.ViewModels"
             xmlns:m="using:ModelMeister.Ui.Models"
             xmlns:conv="using:ModelMeister.Ui.Converters"
             xmlns:svc="using:ModelMeister.Ui.Services"
             xmlns:c="using:ModelMeister.Ui.Controls"
             x:Class="ModelMeister.Ui.Views.CompareLayoutView"
             x:DataType="vm:ICompareViewModel"
             x:Name="LayoutRoot">

  <UserControl.Resources>
    <conv:StageToBrushConverter x:Key="StageBrush" />
    <conv:StageToTextConverter x:Key="StageText" />
    <conv:CompareInSyncConverter x:Key="InSync" />
  </UserControl.Resources>

  <c:PageShell Eyebrow="{Binding #LayoutRoot.Eyebrow}"
               Subtitle="{Binding #LayoutRoot.Subtitle}"
               Status="{Binding Status}"
               IsBusy="{Binding Busy}">

    <Grid RowDefinitions="Auto,*,Auto">

      <!-- Row 0: header card — env pickers + Compare/Save/Copy + extra actions + summary -->
      <Border Grid.Row="0" Classes="card">
        <Grid Margin="14,8" VerticalAlignment="Center"
              ColumnDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,*">

          <ComboBox Grid.Column="0" MinWidth="260"
                    PlaceholderText="Select environment"
                    ItemsSource="{Binding AvailableEnvs}"
                    SelectedItem="{Binding LeftEnv, Mode=TwoWay}"
                    IsEnabled="{Binding !Busy}">
            <ComboBox.ItemTemplate>
              <DataTemplate x:DataType="m:EnvironmentEntry">
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                  <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                  <Border Classes="pill"
                          Background="{Binding Stage, Converter={StaticResource StageBrush}, ConverterParameter=soft}"
                          BorderBrush="{Binding Stage, Converter={StaticResource StageBrush}}"
                          BorderThickness="1" Padding="6,1">
                    <TextBlock Text="{Binding Stage, Converter={StaticResource StageText}}"
                               Foreground="{Binding Stage, Converter={StaticResource StageBrush}}"
                               FontSize="10" FontWeight="SemiBold" />
                  </Border>
                </StackPanel>
              </DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>

          <Button Grid.Column="1" Classes="ghost" Margin="6,0" Padding="8,4"
                  Click="OnSwapClick" VerticalAlignment="Center"
                  IsEnabled="{Binding !Busy}"
                  ToolTip.Tip="Swap source and target, then re-compare. Promotion is one-way (source → target); swap to promote the other direction.">
            <TextBlock Text="⇄" FontSize="15" />
          </Button>

          <ComboBox Grid.Column="2" MinWidth="260"
                    PlaceholderText="Select environment"
                    ItemsSource="{Binding AvailableEnvs}"
                    SelectedItem="{Binding RightEnv, Mode=TwoWay}"
                    IsEnabled="{Binding !Busy}">
            <ComboBox.ItemTemplate>
              <DataTemplate x:DataType="m:EnvironmentEntry">
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                  <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                  <Border Classes="pill"
                          Background="{Binding Stage, Converter={StaticResource StageBrush}, ConverterParameter=soft}"
                          BorderBrush="{Binding Stage, Converter={StaticResource StageBrush}}"
                          BorderThickness="1" Padding="6,1">
                    <TextBlock Text="{Binding Stage, Converter={StaticResource StageText}}"
                               Foreground="{Binding Stage, Converter={StaticResource StageBrush}}"
                               FontSize="10" FontWeight="SemiBold" />
                  </Border>
                </StackPanel>
              </DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>

          <Button Grid.Column="3" Content="Refresh" Margin="14,0,0,0"
                  Command="{Binding CompareCommand}" Classes="primary"
                  ToolTip.Tip="Re-run the compare against both environments" />
          <Button Grid.Column="4" Content="Save CSV" Margin="6,0,0,0"
                  Command="{Binding SaveCsvCommand}" Classes="ghost"
                  IsEnabled="{Binding HasRows}" />
          <!-- Copy md removed: the same data is available via Save CSV and direct row inspection. -->

          <!-- Page-specific extra actions (e.g. Extensions' Push L→R / R→L). -->
          <ItemsControl Grid.Column="6" ItemsSource="{Binding ExtraActions}" Margin="6,0,0,0">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <StackPanel Orientation="Horizontal" Spacing="6" />
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:CompareAction">
                <Button Content="{Binding Label}"
                        Classes.danger="{Binding Destructive}"
                        Classes.primary="{Binding Primary}"
                        Classes.ghost="{Binding !Primary}"
                        Command="{Binding Command}" />
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

          <!-- Summary status text removed: the per-bucket bar chart below already shows differences,
               only-left, only-right, changed counts. Status line at the bottom of the page covers
               the in-flight messages. -->
          <TextBlock Grid.Column="7" Text="" />
        </Grid>
      </Border>

      <!-- Row 1: body slot — the host page's DataGrid is dropped here as Content. Right padding
           keeps the rightmost DataGrid column from being clipped against the card edge. -->
      <Border Grid.Row="1" Classes="card" Margin="0,12,0,0" Padding="0,0,8,0">
        <Grid>
          <ContentPresenter Content="{Binding #LayoutRoot.Body}" />

          <!-- Shared "in sync" affirmation: shown when both envs are picked, the compare finished,
               and there were no differences. One uniform empty state for every compare hub. -->
          <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8"
                      IsHitTestVisible="False">
            <StackPanel.IsVisible>
              <MultiBinding Converter="{StaticResource InSync}">
                <Binding Path="LeftEnv" />
                <Binding Path="RightEnv" />
                <Binding Path="Busy" />
                <Binding Path="HasRows" />
              </MultiBinding>
            </StackPanel.IsVisible>
            <Path Data="{DynamicResource IcoCheck}" Width="28" Height="28" Stretch="Uniform"
                  Stroke="{DynamicResource Success}" StrokeThickness="1.8"
                  StrokeJoin="Round" StrokeLineCap="Round" Fill="Transparent"
                  HorizontalAlignment="Center" />
            <TextBlock Text="In sync" FontWeight="SemiBold" HorizontalAlignment="Center" />
            <TextBlock Text="No differences between these environments." Classes="dim"
                       HorizontalAlignment="Center" />
          </StackPanel>
        </Grid>
      </Border>

      <!-- Row 2: per-bucket bar chart — visible only when there are rows. -->
      <Border Grid.Row="2" Classes="card" Margin="0,12,0,0"
              IsVisible="{Binding HasRows}">
        <ItemsControl ItemsSource="{Binding Counts}" Margin="14,10">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <UniformGrid Columns="4" />
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="vm:ConceptDiffCount">
              <Button Classes="ghost" Padding="6,4" Margin="6,4" Click="OnBucketClick"
                      HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                      ToolTip.Tip="Click to hide/show this bucket's rows in the table"
                      Opacity="{Binding IsHidden, Converter={x:Static svc:Eq.OpacityFor}}">
                <StackPanel Spacing="3">
                  <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0" Text="{Binding Title}" Classes="dim" FontSize="11"
                               TextTrimming="CharacterEllipsis" ToolTip.Tip="{Binding Title}"
                               TextDecorations="{Binding IsHidden, Converter={x:Static svc:Eq.StrikeIfTrue}}" />
                    <TextBlock Grid.Column="1" Text="{Binding Count}" FontSize="11" FontWeight="SemiBold" />
                  </Grid>
                  <Grid Height="6">
                    <Border Background="{DynamicResource BorderFaint}" CornerRadius="3" />
                    <Border HorizontalAlignment="Left" CornerRadius="3" Background="{DynamicResource Accent}">
                      <Border.Width>
                        <MultiBinding Converter="{x:Static conv:FractionWidthConverter.Instance}">
                          <Binding Path="Fraction" />
                          <Binding Path="$parent[Grid].Bounds.Width" />
                        </MultiBinding>
                      </Border.Width>
                    </Border>
                  </Grid>
                </StackPanel>
              </Button>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </Border>

    </Grid>

  </c:PageShell>
</UserControl>
