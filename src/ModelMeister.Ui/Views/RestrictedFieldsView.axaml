<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ModelMeister.Ui.ViewModels"
             xmlns:svc="using:ModelMeister.Ui.Services"
             xmlns:c="using:ModelMeister.Ui.Controls"
             x:Class="ModelMeister.Ui.Views.RestrictedFieldsView"
             x:DataType="vm:RestrictedFieldsViewModel"
             x:Name="PageRoot">

  <UserControl.KeyBindings>
    <KeyBinding Gesture="Delete"
                Command="{Binding DeleteCommand}"
                CommandParameter="{Binding #RestrictedFieldsGrid.SelectedItem}" />
  </UserControl.KeyBindings>

  <c:PageShell Eyebrow="RESTRICTED FIELDS"
               Subtitle="Field restrictions by role on the connected environment — export/import via the icons above"
               Status="{Binding Status}"
               IsBusy="{Binding Busy}">
    <c:PageShell.Actions>
      <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
        <Button Classes="ghost icon danger" ToolTip.Tip="Delete selected restrictions"
                Command="{Binding DeleteSelectedCommand}"
                IsVisible="{Binding Selection.HasSelection}">
          <Path Data="{DynamicResource IcoTrash}" Width="13" Height="13" Stretch="Uniform"
                Stroke="{DynamicResource Danger}" StrokeThickness="1.6"
                StrokeJoin="Round" StrokeLineCap="Round" Fill="Transparent" />
        </Button>
        <Border Width="1" Margin="4,4" Background="{DynamicResource BorderFaint}" />
        <Button Classes="ghost icon" ToolTip.Tip="Download…">
          <Button.Flyout>
            <MenuFlyout Placement="Bottom">
              <MenuItem Header="Download list"     Command="{Binding DownloadListCommand}" />
              <MenuItem Header="Download template" Command="{Binding DownloadTemplateCommand}" />
            </MenuFlyout>
          </Button.Flyout>
          <Path Data="{DynamicResource IcoDownload}" Width="14" Height="14" Stretch="Uniform"
                Stroke="{DynamicResource TextSec}" StrokeThickness="1.6"
                StrokeJoin="Round" StrokeLineCap="Round" Fill="Transparent" />
        </Button>
        <c:PageActions DataContext="{Binding}" />
      </StackPanel>
    </c:PageShell.Actions>

    <Border Classes="card flush" Padding="0">
      <DockPanel LastChildFill="True">
        <c:GridToolbar DockPanel.Dock="Top" Margin="8,8,8,4" TargetGrid="{Binding #RestrictedFieldsGrid}" />
        <Grid>
          <!-- Empty state: when no restrictions (typically because we're not connected) -->
          <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                      Spacing="6" Margin="0,40"
                      IsVisible="{Binding Rows.Count, Converter={x:Static svc:Eq.IsZero}}">
            <TextBlock Text="No restricted-field permissions to show" FontWeight="SemiBold" FontSize="14" HorizontalAlignment="Center" />
            <TextBlock Text="Connect to an environment to see its field restrictions." Classes="subtle" HorizontalAlignment="Center" />
          </StackPanel>
          <DataGrid Name="RestrictedFieldsGrid"
                    ItemsSource="{Binding Rows}" IsReadOnly="True"
                    AutoGenerateColumns="False"
                    GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                    BorderThickness="0" svc:GridSelectionBehavior.Enable="True">
            <DataGrid.ContextMenu>
              <ContextMenu>
                <MenuItem Header="Copy role"
                          Command="{Binding CopyRoleCommand}"
                          CommandParameter="{Binding #RestrictedFieldsGrid.SelectedItem}" />
                <MenuItem Header="Copy key"
                          Command="{Binding CopyKeyCommand}"
                          CommandParameter="{Binding #RestrictedFieldsGrid.SelectedItem}" />
                <Separator />
                <MenuItem Header="Delete"
                          Command="{Binding DeleteCommand}"
                          CommandParameter="{Binding #RestrictedFieldsGrid.SelectedItem}" />
                <MenuItem Header="Delete selected"
                          Command="{Binding DeleteSelectedCommand}"
                          IsEnabled="{Binding Selection.HasSelection}" />
              </ContextMenu>
            </DataGrid.ContextMenu>
            <DataGrid.Columns>
              <DataGridTemplateColumn Width="40" CanUserResize="False" CanUserReorder="False" CanUserSort="False"
                                      CellTemplate="{StaticResource RowSelectCell}">
                <DataGridTemplateColumn.Header>
                  <CheckBox IsChecked="{Binding #PageRoot.((vm:RestrictedFieldsViewModel)DataContext).Selection.AllSelected, Mode=TwoWay}"
                            HorizontalAlignment="Center" VerticalAlignment="Center" ToolTip.Tip="Select all" />
                </DataGridTemplateColumn.Header>
              </DataGridTemplateColumn>
              <DataGridTextColumn Binding="{Binding RoleName}" Width="200" MinWidth="120">
                <DataGridTextColumn.Header><c:FilterableHeader Title="Role" Path="RoleName" /></DataGridTextColumn.Header>
              </DataGridTextColumn>
              <DataGridTextColumn Binding="{Binding RestrictionType}" Width="140" MinWidth="100">
                <DataGridTextColumn.Header><c:FilterableHeader Title="Restriction" Path="RestrictionType" /></DataGridTextColumn.Header>
              </DataGridTextColumn>
              <DataGridTextColumn Binding="{Binding EntityTypeId}" Width="1.4*" MinWidth="120">
                <DataGridTextColumn.Header><c:FilterableHeader Title="Entity type" Path="EntityTypeId" /></DataGridTextColumn.Header>
              </DataGridTextColumn>
              <DataGridTextColumn Binding="{Binding FieldTypeId}" Width="1.4*" MinWidth="120">
                <DataGridTextColumn.Header><c:FilterableHeader Title="Field type" Path="FieldTypeId" /></DataGridTextColumn.Header>
              </DataGridTextColumn>
              <DataGridTextColumn Binding="{Binding CategoryId}" Width="1.4*" MinWidth="120">
                <DataGridTextColumn.Header><c:FilterableHeader Title="Category" Path="CategoryId" /></DataGridTextColumn.Header>
              </DataGridTextColumn>

              <DataGridTemplateColumn Header="" Width="60">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate x:DataType="vm:RestrictedFieldListRow">
                    <Button Classes="ghost icon danger" Padding="6" Margin="4,0" ToolTip.Tip="Delete"
                            Command="{Binding $parent[DataGrid].((vm:RestrictedFieldsViewModel)DataContext).DeleteCommand}"
                            CommandParameter="{Binding}">
                      <Path Data="{DynamicResource IcoTrash}" Width="12" Height="12" Stretch="Uniform"
                            Stroke="{DynamicResource Danger}" StrokeThickness="1.6" Fill="Transparent" />
                    </Button>
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>
            </DataGrid.Columns>
          </DataGrid>
        </Grid>
      </DockPanel>
    </Border>

  </c:PageShell>
</UserControl>
