<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ModelMeister.Ui.ViewModels"
             xmlns:svc="using:ModelMeister.Ui.Services"
             xmlns:c="using:ModelMeister.Ui.Controls"
             x:Class="ModelMeister.Ui.Views.ServerSettingsView"
             x:DataType="vm:ServerSettingsViewModel"
             x:Name="PageRoot">

  <UserControl.KeyBindings>
    <KeyBinding Gesture="Delete" Command="{Binding DeleteSelectedCommand}" />
    <KeyBinding Gesture="Escape" Command="{Binding Selection.ClearCommand}" />
    <KeyBinding Gesture="Ctrl+A" Command="{Binding Selection.SelectAllVisibleCommand}" />
  </UserControl.KeyBindings>

  <c:PageShell Eyebrow="SERVER SETTINGS"
               Subtitle="Key/value settings on the connected environment"
               Status="{Binding Status}"
               IsBusy="{Binding Busy}">
    <c:PageShell.Actions>
      <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
        <!-- + Add as the leftmost action with pipe separator before the standard metadata icons.
             The previous inline form at the top of the page is replaced by a modal dialog. -->
        <Button Classes="ghost icon" ToolTip.Tip="New server setting"
                Command="{Binding AddCommand}" IsEnabled="{Binding !Busy}">
          <Path Data="{DynamicResource IcoPlus}" Width="13" Height="13" Stretch="Uniform"
                Stroke="{DynamicResource TextSec}" StrokeThickness="1.8"
                StrokeJoin="Round" StrokeLineCap="Round" Fill="Transparent" />
        </Button>
        <Button Classes="ghost icon danger" ToolTip.Tip="Delete selected settings"
                Command="{Binding DeleteSelectedCommand}"
                IsVisible="{Binding Selection.HasSelection}">
          <Path Data="{DynamicResource IcoTrash}" Width="13" Height="13" Stretch="Uniform"
                Stroke="{DynamicResource Danger}" StrokeThickness="1.6"
                StrokeJoin="Round" StrokeLineCap="Round" Fill="Transparent" />
        </Button>
        <Border Width="1" Margin="4,4" Background="{DynamicResource BorderFaint}" />
        <c:ExcelMenu DataContext="{Binding}" />
        <c:PageActions DataContext="{Binding}" />
      </StackPanel>
    </c:PageShell.Actions>

    <Border Classes="card flush" Padding="0">
      <!-- The grid is read-only (no inline editing) so users can freely select cell text without
           triggering an edit. Mutation happens through Edit / Delete / Copy icons per row, each
           routed through a popup. -->
      <DockPanel LastChildFill="True">
      <c:GridToolbar DockPanel.Dock="Top" Margin="8,8,8,4" TargetGrid="{Binding #SettingsGrid}" />
      <Grid>
        <!-- Empty state: shown when no settings (typically because we're not connected). Mirrors
             UsersView so an empty list isn't a blank dark surface. -->
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                    Spacing="6" Margin="0,40"
                    IsVisible="{Binding Rows.Count, Converter={x:Static svc:Eq.IsZero}}">
          <TextBlock Text="No server settings to show" FontWeight="SemiBold" FontSize="14" HorizontalAlignment="Center" />
          <TextBlock Text="Connect to an environment to see its settings." Classes="subtle" HorizontalAlignment="Center" />
        </StackPanel>
      <DataGrid Name="SettingsGrid"
                ItemsSource="{Binding Rows}" IsReadOnly="True"
                AutoGenerateColumns="False" SelectionMode="Single"
                GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                Margin="0" BorderThickness="0" CornerRadius="0"
                svc:GridSelectionBehavior.Selection="{Binding Selection}">
        <DataGrid.ContextMenu>
          <ContextMenu>
            <MenuItem Header="Edit"
                      Command="{Binding EditCommand}"
                      CommandParameter="{Binding #SettingsGrid.SelectedItem}" />
            <MenuItem Header="Copy key"
                      Command="{Binding CopyKeyCommand}"
                      CommandParameter="{Binding #SettingsGrid.SelectedItem}" />
            <MenuItem Header="Copy value"
                      Command="{Binding CopyValueCommand}"
                      CommandParameter="{Binding #SettingsGrid.SelectedItem}" />
            <Separator />
            <MenuItem Header="Delete"
                      Command="{Binding ConfirmAndDeleteCommand}"
                      CommandParameter="{Binding #SettingsGrid.SelectedItem}" />
            <MenuItem Header="Delete selected"
                      Command="{Binding DeleteSelectedCommand}"
                      IsEnabled="{Binding Selection.HasSelection}" />
          </ContextMenu>
        </DataGrid.ContextMenu>
        <DataGrid.Columns>
          <DataGridTemplateColumn Width="40" CanUserResize="False" CanUserReorder="False" CanUserSort="False"
                                  CellTemplate="{StaticResource RowSelectCell}">
            <DataGridTemplateColumn.Header>
              <CheckBox IsChecked="{Binding #PageRoot.((vm:ServerSettingsViewModel)DataContext).Selection.AllSelected, Mode=TwoWay}"
                        ToolTip.Tip="Select all" />
            </DataGridTemplateColumn.Header>
          </DataGridTemplateColumn>
          <!-- Star widths so the grid always fills the window; Value gets the larger share. The key
               column keeps a sensible floor instead of a fixed 320 that left dead space on wide windows. -->
          <DataGridTextColumn Binding="{Binding Key}" Width="*" MinWidth="220">
            <DataGridTextColumn.Header><c:FilterableHeader Title="Key" Path="Key" /></DataGridTextColumn.Header>
          </DataGridTextColumn>
          <DataGridTextColumn Binding="{Binding Value}" Width="2*" MinWidth="240">
            <DataGridTextColumn.Header><c:FilterableHeader Title="Value" Path="Value" /></DataGridTextColumn.Header>
          </DataGridTextColumn>

          <DataGridTemplateColumn Header="" Width="130">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate x:DataType="vm:ServerSettingEditRow">
                <StackPanel Orientation="Horizontal" Spacing="3" Margin="4,0">
                  <Button Classes="ghost icon" Padding="6" ToolTip.Tip="Edit"
                          Command="{Binding $parent[DataGrid].((vm:ServerSettingsViewModel)DataContext).EditCommand}"
                          CommandParameter="{Binding}">
                    <Path Data="{DynamicResource IcoEdit}" Width="12" Height="12" Stretch="Uniform"
                          Stroke="{DynamicResource TextSec}" StrokeThickness="1.6" Fill="Transparent" />
                  </Button>
                  <Button Classes="ghost icon" Padding="6" ToolTip.Tip="Copy key + value"
                          Command="{Binding $parent[DataGrid].((vm:ServerSettingsViewModel)DataContext).CopyValueCommand}"
                          CommandParameter="{Binding}">
                    <Path Data="{DynamicResource IcoCopy}" Width="12" Height="12" Stretch="Uniform"
                          Stroke="{DynamicResource TextSec}" StrokeThickness="1.6" Fill="Transparent" />
                  </Button>
                  <Button Classes="ghost icon danger" Padding="6" ToolTip.Tip="Delete"
                          Command="{Binding $parent[DataGrid].((vm:ServerSettingsViewModel)DataContext).ConfirmAndDeleteCommand}"
                          CommandParameter="{Binding}">
                    <Path Data="{DynamicResource IcoTrash}" Width="12" Height="12" Stretch="Uniform"
                          Stroke="{DynamicResource Danger}" StrokeThickness="1.6" Fill="Transparent" />
                  </Button>
                </StackPanel>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>
        </DataGrid.Columns>
      </DataGrid>
      </Grid>
      </DockPanel>
    </Border>

  </c:PageShell>
</UserControl>
