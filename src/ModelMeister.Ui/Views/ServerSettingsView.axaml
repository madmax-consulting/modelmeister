<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ModelMeister.Ui.ViewModels"
             xmlns:c="using:ModelMeister.Ui.Controls"
             xmlns:conv="using:ModelMeister.Ui.Converters"
             xmlns:svc="using:ModelMeister.Ui.Services"
             xmlns:views="using:ModelMeister.Ui.Views"
             x:Class="ModelMeister.Ui.Views.ServerSettingsView"
             x:DataType="vm:ServerSettingsViewModel"
             x:Name="Root">

  <UserControl.Resources>
    <conv:StageToBrushConverter x:Key="StageBrush" />
    <conv:StageToTextConverter x:Key="StageText" />
  </UserControl.Resources>

  <!-- The CompareLayoutView already supplies a full PageShell (eyebrow/subtitle/status). Wrapping it
       in another DockPanel + status strip would stack two headers; let the layout own the chrome. -->
  <views:CompareLayoutView Eyebrow="SERVER SETTINGS · COMPARE"
                           Subtitle="Compare server settings across two environments — promote per-key">
    <views:CompareLayoutView.Body>
      <DockPanel LastChildFill="True">
        <c:GridToolbar DockPanel.Dock="Top" Margin="2,0,0,8" TargetGrid="{Binding #MainGrid}" />
        <DataGrid Name="MainGrid" ItemsSource="{Binding Rows}" IsReadOnly="True"
                  AutoGenerateColumns="False" SelectionMode="Extended"
                  svc:MultiSelectBehavior.Selection="{Binding SelectedRows}"
                  GridLinesVisibility="Horizontal" HeadersVisibility="Column" Classes="filterable fit">
          <DataGrid.Columns>
            <DataGridTextColumn Binding="{Binding State}" Width="100">
              <DataGridTextColumn.Header><c:FilterableHeader Title="State" Path="State" /></DataGridTextColumn.Header>
            </DataGridTextColumn>
            <DataGridTextColumn Binding="{Binding Key}" Width="1.2*" MinWidth="120">
              <DataGridTextColumn.Header><c:FilterableHeader Title="Key" Path="Key" /></DataGridTextColumn.Header>
            </DataGridTextColumn>

            <DataGridTemplateColumn Width="1.4*" MinWidth="90" CanUserSort="True" SortMemberPath="LeftDisplay">
              <DataGridTemplateColumn.Header>
                <c:FilterableHeader Path="LeftDisplay">
                  <c:FilterableHeader.Title>
                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                      <TextBlock Text="{Binding #Root.((vm:ServerSettingsViewModel)DataContext).LeftColumnHeader}" />
                      <Border Classes="pill"
                              Background="{Binding #Root.((vm:ServerSettingsViewModel)DataContext).LeftColumnStage, Converter={StaticResource StageBrush}, ConverterParameter=soft}"
                              BorderBrush="{Binding #Root.((vm:ServerSettingsViewModel)DataContext).LeftColumnStage, Converter={StaticResource StageBrush}}"
                              BorderThickness="1" Padding="5,0">
                        <TextBlock Text="{Binding #Root.((vm:ServerSettingsViewModel)DataContext).LeftColumnStage, Converter={StaticResource StageText}}"
                                   Foreground="{Binding #Root.((vm:ServerSettingsViewModel)DataContext).LeftColumnStage, Converter={StaticResource StageBrush}}"
                                   FontSize="9" FontWeight="SemiBold" />
                      </Border>
                    </StackPanel>
                  </c:FilterableHeader.Title>
                </c:FilterableHeader>
              </DataGridTemplateColumn.Header>
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate x:DataType="vm:ServerSettingRow">
                  <TextBlock Text="{Binding LeftDisplay}" VerticalAlignment="Center" Margin="8,0" />
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>

            <DataGridTemplateColumn Width="1.4*" MinWidth="90" CanUserSort="True" SortMemberPath="RightDisplay">
              <DataGridTemplateColumn.Header>
                <c:FilterableHeader Path="RightDisplay">
                  <c:FilterableHeader.Title>
                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                      <TextBlock Text="{Binding #Root.((vm:ServerSettingsViewModel)DataContext).RightColumnHeader}" />
                      <Border Classes="pill"
                              Background="{Binding #Root.((vm:ServerSettingsViewModel)DataContext).RightColumnStage, Converter={StaticResource StageBrush}, ConverterParameter=soft}"
                              BorderBrush="{Binding #Root.((vm:ServerSettingsViewModel)DataContext).RightColumnStage, Converter={StaticResource StageBrush}}"
                              BorderThickness="1" Padding="5,0">
                        <TextBlock Text="{Binding #Root.((vm:ServerSettingsViewModel)DataContext).RightColumnStage, Converter={StaticResource StageText}}"
                                   Foreground="{Binding #Root.((vm:ServerSettingsViewModel)DataContext).RightColumnStage, Converter={StaticResource StageBrush}}"
                                   FontSize="9" FontWeight="SemiBold" />
                      </Border>
                    </StackPanel>
                  </c:FilterableHeader.Title>
                </c:FilterableHeader>
              </DataGridTemplateColumn.Header>
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate x:DataType="vm:ServerSettingRow">
                  <TextBlock Text="{Binding RightDisplay}" VerticalAlignment="Center" Margin="8,0" />
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>

            <!-- Per-row apply (one-way: source → target). Direction is shown as source→target stage
                 pills (e.g. [DEV]→[PROD]). Swap the environments to apply the other direction. -->
            <DataGridTemplateColumn Header="" Width="100">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate x:DataType="vm:ServerSettingRow">
                  <StackPanel Orientation="Horizontal" Spacing="6" Margin="4,0">
                    <Button Classes="ghost" Padding="4,2"
                            ToolTip.Tip="Apply left value to right environment"
                            Command="{Binding $parent[DataGrid].((vm:ServerSettingsViewModel)DataContext).ApplyLeftToRightCommand}"
                            CommandParameter="{Binding}">
                      <StackPanel Orientation="Horizontal" Spacing="3" VerticalAlignment="Center">
                        <Border Classes="pill"
                                Background="{Binding $parent[DataGrid].((vm:ServerSettingsViewModel)DataContext).LeftColumnStage, Converter={StaticResource StageBrush}, ConverterParameter=soft}"
                                BorderBrush="{Binding $parent[DataGrid].((vm:ServerSettingsViewModel)DataContext).LeftColumnStage, Converter={StaticResource StageBrush}}"
                                BorderThickness="1" Padding="4,0">
                          <TextBlock Text="{Binding $parent[DataGrid].((vm:ServerSettingsViewModel)DataContext).LeftColumnStage, Converter={StaticResource StageText}}"
                                     Foreground="{Binding $parent[DataGrid].((vm:ServerSettingsViewModel)DataContext).LeftColumnStage, Converter={StaticResource StageBrush}}"
                                     FontSize="9" FontWeight="SemiBold" />
                        </Border>
                        <TextBlock Text="→" VerticalAlignment="Center" />
                        <Border Classes="pill"
                                Background="{Binding $parent[DataGrid].((vm:ServerSettingsViewModel)DataContext).RightColumnStage, Converter={StaticResource StageBrush}, ConverterParameter=soft}"
                                BorderBrush="{Binding $parent[DataGrid].((vm:ServerSettingsViewModel)DataContext).RightColumnStage, Converter={StaticResource StageBrush}}"
                                BorderThickness="1" Padding="4,0">
                          <TextBlock Text="{Binding $parent[DataGrid].((vm:ServerSettingsViewModel)DataContext).RightColumnStage, Converter={StaticResource StageText}}"
                                     Foreground="{Binding $parent[DataGrid].((vm:ServerSettingsViewModel)DataContext).RightColumnStage, Converter={StaticResource StageBrush}}"
                                     FontSize="9" FontWeight="SemiBold" />
                        </Border>
                      </StackPanel>
                    </Button>
                  </StackPanel>
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>
          </DataGrid.Columns>
        </DataGrid>
      </DockPanel>
    </views:CompareLayoutView.Body>
  </views:CompareLayoutView>
</UserControl>
