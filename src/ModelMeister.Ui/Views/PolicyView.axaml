<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ModelMeister.Ui.ViewModels"
             xmlns:c="using:ModelMeister.Ui.Controls"
             x:Class="ModelMeister.Ui.Views.PolicyView"
             x:DataType="vm:PolicyViewModel">

  <c:PageShell Eyebrow="MERGE POLICY"
               Subtitle="Choose what diff operations are permitted when applying changes to inriver">

    <ScrollViewer HorizontalScrollBarVisibility="Disabled">
      <StackPanel Spacing="12">

        <!-- Policy card -->
        <Border Classes="card">
          <StackPanel Spacing="10">

            <Grid ColumnDefinitions="Auto,*">
              <CheckBox Grid.Column="0" Content="Overwrite names &amp; descriptions"
                        IsChecked="{Binding OverwriteNamesAndDescriptions, Mode=TwoWay}" />
              <TextBlock Grid.Column="1" Classes="dim" VerticalAlignment="Center" Margin="14,0,0,0"
                         Text="When code differs from inriver, push the code-side display strings (Name, Description)." />
            </Grid>

            <Grid ColumnDefinitions="Auto,*">
              <CheckBox Grid.Column="0" Content="Overwrite CVL values"
                        IsChecked="{Binding OverwriteCvlValues, Mode=TwoWay}" />
              <TextBlock Grid.Column="1" Classes="dim" VerticalAlignment="Center" Margin="14,0,0,0"
                         Text="Allow updates to the label/index of existing CVL values." />
            </Grid>

            <Grid ColumnDefinitions="Auto,*">
              <CheckBox Grid.Column="0" Content="Allow deletes"
                        IsChecked="{Binding AllowDeletes, Mode=TwoWay}" />
              <TextBlock Grid.Column="1" Classes="dim" VerticalAlignment="Center" Margin="14,0,0,0"
                         Text="Allow Delete / Deactivate operations on concepts that exist in inriver but not in code. While off, such deletes are skipped and reported as &quot;suppressed by policy&quot; on the Compare page rather than applied." />
            </Grid>

            <Grid ColumnDefinitions="Auto,*">
              <CheckBox Grid.Column="0" Content="Allow datatype change (dangerous)"
                        IsChecked="{Binding AllowDatatypeChange, Mode=TwoWay}" />
              <TextBlock Grid.Column="1" Classes="dim" VerticalAlignment="Center" Margin="14,0,0,0"
                         Text="Allow a field's datatype to change. Inriver may drop or coerce existing values. While off, datatype changes are skipped and reported as &quot;suppressed by policy&quot; on the Compare page." />
            </Grid>

            <Grid ColumnDefinitions="Auto,*">
              <CheckBox Grid.Column="0" Content="Allow CVL value rename"
                        IsChecked="{Binding AllowCvlValueRename, Mode=TwoWay}" />
              <TextBlock Grid.Column="1" Classes="dim" VerticalAlignment="Center" Margin="14,0,0,0"
                         Text="Permit renaming an existing CVL value's key (migrate references). Most setups do not need this." />
            </Grid>

            <Grid ColumnDefinitions="Auto,*">
              <CheckBox Grid.Column="0" Content="Apply field index/sort order"
                        IsChecked="{Binding ApplyFieldIndexChanges, Mode=TwoWay}" />
              <TextBlock Grid.Column="1" Classes="dim" VerticalAlignment="Center" Margin="14,0,0,0"
                         Text="Surface and apply field-type sort-order (Index) changes on update. Off by default — index differences are ignored." />
            </Grid>

            <Grid ColumnDefinitions="Auto,*">
              <CheckBox Grid.Column="0" Content="Apply category index/sort order"
                        IsChecked="{Binding ApplyCategoryIndexChanges, Mode=TwoWay}" />
              <TextBlock Grid.Column="1" Classes="dim" VerticalAlignment="Center" Margin="14,0,0,0"
                         Text="Surface and apply category sort-order (Index) changes on update. Off by default — index differences are ignored." />
            </Grid>

            <Grid ColumnDefinitions="Auto,*">
              <CheckBox Grid.Column="0" Content="Apply link index/sort order"
                        IsChecked="{Binding ApplyLinkTypeIndexChanges, Mode=TwoWay}" />
              <TextBlock Grid.Column="1" Classes="dim" VerticalAlignment="Center" Margin="14,0,0,0"
                         Text="Surface and apply link-type sort-order (Index) changes on update. Off by default — index differences are ignored." />
            </Grid>
          </StackPanel>
        </Border>

        <!-- Ignore field-type properties -->
        <Border Classes="card">
          <StackPanel Spacing="8">
            <TextBlock Text="IGNORE FIELD PROPERTIES" Classes="h3" />
            <TextBlock Classes="dim"
                       Text="Differences in the checked properties are ignored across all field types — they never surface as a change." />
            <ItemsControl ItemsSource="{Binding IgnorableProperties}" Margin="0,4,0,0">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <WrapPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:FieldPropertyIgnoreToggle">
                  <CheckBox Width="200" Margin="0,2"
                            Content="{Binding Property}"
                            IsChecked="{Binding Ignored, Mode=TwoWay}" />
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </Border>

        <!-- Ignore field-type ids by pattern -->
        <Border Classes="card">
          <StackPanel Spacing="8">
            <TextBlock Text="IGNORE FIELD IDS" Classes="h3" />
            <TextBlock Classes="dim"
                       Text="Field types whose id matches a rule are ignored entirely (no add, update, or delete)." />

            <ItemsControl ItemsSource="{Binding FieldIdRules}" Margin="0,4,0,0">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:FieldIdRuleRow">
                  <Grid ColumnDefinitions="140,*,Auto" Margin="0,3">
                    <ComboBox Grid.Column="0" MinWidth="130"
                              ItemsSource="{Binding $parent[ItemsControl].((vm:PolicyViewModel)DataContext).MatchKinds}"
                              SelectedItem="{Binding Kind, Mode=TwoWay}" />
                    <TextBox Grid.Column="1" Margin="8,0,0,0" Watermark="id fragment, e.g. _internal"
                             Text="{Binding Value, Mode=TwoWay}" />
                    <Button Grid.Column="2" Margin="8,0,0,0" Content="Remove"
                            Command="{Binding $parent[ItemsControl].((vm:PolicyViewModel)DataContext).RemoveFieldIdRuleCommand}"
                            CommandParameter="{Binding}" />
                  </Grid>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Button Content="Add rule" HorizontalAlignment="Left" Margin="0,4,0,0"
                    Command="{Binding AddFieldIdRuleCommand}" />
          </StackPanel>
        </Border>

        <!-- Footer: current policy summary -->
        <Border Classes="card">
          <StackPanel Spacing="4">
            <TextBlock Text="CURRENT POLICY" Classes="h3" />
            <TextBlock Text="{Binding Summary}" Classes="subtle" />
          </StackPanel>
        </Border>

      </StackPanel>
    </ScrollViewer>

  </c:PageShell>
</UserControl>
