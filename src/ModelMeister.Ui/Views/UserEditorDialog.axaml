<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ModelMeister.Ui.ViewModels"
        x:Class="ModelMeister.Ui.Views.UserEditorDialog"
        x:DataType="vm:UserEditorViewModel"
        Title="{Binding Title}"
        Width="560" Height="660"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="{DynamicResource Surface0}"
        FontFamily="{StaticResource UiFont}">

  <Border Padding="0" Background="{DynamicResource AppBackground}">
    <DockPanel Margin="28,26,28,24" LastChildFill="True">

      <StackPanel DockPanel.Dock="Top" Spacing="2">
        <TextBlock Text="USER" Classes="eyebrow" />
        <TextBlock Text="{Binding Title}" FontSize="20" FontWeight="Bold" />
      </StackPanel>

      <StackPanel DockPanel.Dock="Top" Spacing="4" Margin="0,14,0,0">
        <TextBlock Text="Username" Classes="label" />
        <TextBox Text="{Binding Username, Mode=TwoWay}" Watermark="login / username"
                 IsReadOnly="{Binding IsEdit}" />
      </StackPanel>

      <Grid DockPanel.Dock="Top" Margin="0,12,0,0" ColumnDefinitions="*,12,*">
        <StackPanel Grid.Column="0" Spacing="4">
          <TextBlock Text="First name" Classes="label" />
          <TextBox Text="{Binding FirstName, Mode=TwoWay}" Watermark="First name" />
        </StackPanel>
        <StackPanel Grid.Column="2" Spacing="4">
          <TextBlock Text="Last name" Classes="label" />
          <TextBox Text="{Binding LastName, Mode=TwoWay}" Watermark="Last name" />
        </StackPanel>
      </Grid>

      <StackPanel DockPanel.Dock="Top" Spacing="4" Margin="0,12,0,0">
        <TextBlock Text="Email" Classes="label" />
        <TextBox Text="{Binding Email, Mode=TwoWay}" Watermark="name@example.com" />
      </StackPanel>

      <StackPanel DockPanel.Dock="Top" Spacing="4" Margin="0,12,0,0" HorizontalAlignment="Left">
        <TextBlock Text="Language" Classes="label" />
        <TextBox Text="{Binding Language, Mode=TwoWay}" Width="90" Watermark="en" />
      </StackPanel>

      <CheckBox DockPanel.Dock="Top" Margin="0,12,0,0"
                Content="Generate a REST API key for this user"
                IsChecked="{Binding GenerateApiKey, Mode=TwoWay}"
                IsVisible="{Binding !IsEdit}" />

      <TextBlock DockPanel.Dock="Top" Text="Roles" Classes="label" Margin="0,14,0,4" />

      <!-- Buttons + validation pinned to the bottom; the role list fills the rest. -->
      <StackPanel DockPanel.Dock="Bottom" Spacing="10" Margin="0,12,0,0">
        <TextBlock Text="{Binding Validation}" Foreground="{DynamicResource Danger}"
                   IsVisible="{Binding Validation, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
          <Button Content="Abort" Command="{Binding AbortCommand}" IsCancel="True" />
          <Button Content="Save" Command="{Binding ConfirmCommand}" Classes="primary" IsDefault="True" />
        </StackPanel>
      </StackPanel>

      <Border Classes="cardSubtle" Padding="6">
        <ScrollViewer>
          <ItemsControl ItemsSource="{Binding Roles}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:RoleToggle">
                <CheckBox Content="{Binding Name}" IsChecked="{Binding IsSelected, Mode=TwoWay}" Margin="2,1" />
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
      </Border>

    </DockPanel>
  </Border>
</Window>
