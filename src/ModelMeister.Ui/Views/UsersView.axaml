<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ModelMeister.Ui.ViewModels"
             xmlns:svc="using:ModelMeister.Ui.Services"
             xmlns:c="using:ModelMeister.Ui.Controls"
             xmlns:conv="using:ModelMeister.Ui.Converters"
             x:Class="ModelMeister.Ui.Views.UsersView"
             x:DataType="vm:UsersViewModel"
             x:Name="PageRoot">

  <UserControl.KeyBindings>
    <KeyBinding Gesture="Escape" Command="{Binding Selection.ClearCommand}" />
    <KeyBinding Gesture="Ctrl+A" Command="{Binding Selection.SelectAllVisibleCommand}" />
    <KeyBinding Gesture="Ctrl+C" Command="{Binding CopySelectedCommand}" />
  </UserControl.KeyBindings>

  <c:PageShell Eyebrow="USERS"
               Subtitle="Inspect, create, and edit the live environment's users — export/import via the icons above"
               Status="{Binding Status}"
               IsBusy="{Binding Busy}">
    <c:PageShell.Actions>
      <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
        <Button Classes="ghost icon" ToolTip.Tip="New user"
                Command="{Binding AddUserCommand}">
          <Path Data="{DynamicResource IcoPlus}" Width="13" Height="13" Stretch="Uniform"
                Stroke="{DynamicResource TextSec}" StrokeThickness="1.8"
                StrokeJoin="Round" StrokeLineCap="Round" Fill="Transparent" />
        </Button>
        <Button Classes="ghost icon" ToolTip.Tip="Add or remove a role on selected users"
                Command="{Binding BulkSetRoleCommand}"
                IsVisible="{Binding Selection.HasSelection}">
          <Path Data="{DynamicResource IcoUsers}" Width="14" Height="14" Stretch="Uniform"
                Stroke="{DynamicResource TextSec}" StrokeThickness="1.6"
                StrokeJoin="Round" StrokeLineCap="Round" Fill="Transparent" />
        </Button>
        <!-- Copy selected: another bulk action available on Users. -->
        <Button Classes="ghost icon" ToolTip.Tip="Copy selected users"
                Command="{Binding CopySelectedCommand}"
                IsVisible="{Binding Selection.HasSelection}">
          <Path Data="{DynamicResource IcoCopy}" Width="13" Height="13" Stretch="Uniform"
                Stroke="{DynamicResource TextSec}" StrokeThickness="1.6"
                StrokeJoin="Round" StrokeLineCap="Round" Fill="Transparent" />
        </Button>
        <Border Width="1" Margin="4,4" Background="{DynamicResource BorderFaint}" />
        <c:ExcelMenu DataContext="{Binding}" />
        <c:PageActions DataContext="{Binding}" />
      </StackPanel>
    </c:PageShell.Actions>

    <Border Classes="card flush" Padding="0">
      <DockPanel LastChildFill="True">
      <c:GridToolbar DockPanel.Dock="Top" Margin="8,8,8,4" TargetGrid="{Binding #UsersGrid}" />
      <Grid>
        <!-- Empty state: when no users (typically because we're not connected) -->
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                    Spacing="6" Margin="0,40"
                    IsVisible="{Binding Users.Count, Converter={x:Static svc:Eq.IsZero}}">
          <TextBlock Text="No users to show" FontWeight="SemiBold" FontSize="14" HorizontalAlignment="Center" />
          <TextBlock Text="Connect to an environment to see its users." Classes="subtle" HorizontalAlignment="Center" />
        </StackPanel>
      <DataGrid Name="UsersGrid"
                ItemsSource="{Binding Users}" IsReadOnly="True"
                AutoGenerateColumns="False" GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                BorderThickness="0" svc:GridSelectionBehavior.Selection="{Binding Selection}">
        <DataGrid.ContextMenu>
          <ContextMenu>
            <MenuItem Header="Edit"
                      Command="{Binding EditUserCommand}"
                      CommandParameter="{Binding #UsersGrid.SelectedItem}" />
            <Separator />
            <MenuItem Header="Copy username"
                      Command="{Binding CopyUsernameCommand}"
                      CommandParameter="{Binding #UsersGrid.SelectedItem}" />
            <MenuItem Header="Copy email"
                      Command="{Binding CopyEmailCommand}"
                      CommandParameter="{Binding #UsersGrid.SelectedItem}" />
            <MenuItem Header="Copy roles"
                      Command="{Binding CopyRolesCommand}"
                      CommandParameter="{Binding #UsersGrid.SelectedItem}" />
          </ContextMenu>
        </DataGrid.ContextMenu>
        <DataGrid.Columns>
          <DataGridTemplateColumn Width="40" CanUserResize="False" CanUserReorder="False" CanUserSort="False"
                                  CellTemplate="{StaticResource RowSelectCell}">
            <DataGridTemplateColumn.Header>
              <CheckBox IsChecked="{Binding #PageRoot.((vm:UsersViewModel)DataContext).Selection.AllSelected, Mode=TwoWay}"
                        HorizontalAlignment="Center" VerticalAlignment="Center" ToolTip.Tip="Select all" />
            </DataGridTemplateColumn.Header>
          </DataGridTemplateColumn>
          <!-- Username + Email are identical in inriver for most orgs; only Username is shown.
               If you need to see Email separately, right-click → Copy email or re-add the column. -->
          <!-- Star widths so the grid fills the window on any size; MinWidths keep the filter header
               boxes legible. Username + Roles get the larger shares. -->
          <DataGridTextColumn Binding="{Binding Username}" Width="1.4*" MinWidth="140">
            <DataGridTextColumn.Header><c:FilterableHeader Title="Username" Path="Username" /></DataGridTextColumn.Header>
          </DataGridTextColumn>
          <DataGridTextColumn Binding="{Binding FirstName}" Width="*" MinWidth="100">
            <DataGridTextColumn.Header><c:FilterableHeader Title="First name" Path="FirstName" /></DataGridTextColumn.Header>
          </DataGridTextColumn>
          <DataGridTextColumn Binding="{Binding LastName}" Width="*" MinWidth="100">
            <DataGridTextColumn.Header><c:FilterableHeader Title="Last name" Path="LastName" /></DataGridTextColumn.Header>
          </DataGridTextColumn>
          <!-- Roles column: comma-joined for read; copy via context menu. -->
          <DataGridTextColumn Binding="{Binding Roles, Converter={x:Static conv:JoinStringsConverter.Instance}}" Width="2*" MinWidth="160">
            <DataGridTextColumn.Header><c:FilterableHeader Title="Roles" Path="Roles" /></DataGridTextColumn.Header>
          </DataGridTextColumn>
          <DataGridTemplateColumn Header="" Width="60">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate x:DataType="vm:UserListRow">
                <Button Classes="ghost icon" Padding="6" Margin="4,0" ToolTip.Tip="Edit"
                        Command="{Binding $parent[DataGrid].((vm:UsersViewModel)DataContext).EditUserCommand}"
                        CommandParameter="{Binding}">
                  <Path Data="{DynamicResource IcoEdit}" Width="12" Height="12" Stretch="Uniform"
                        Stroke="{DynamicResource TextSec}" StrokeThickness="1.6" Fill="Transparent" />
                </Button>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>
        </DataGrid.Columns>
      </DataGrid>
      </Grid>
      </DockPanel>
    </Border>

  </c:PageShell>
</UserControl>
