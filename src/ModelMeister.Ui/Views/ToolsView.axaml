<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ModelMeister.Ui.ViewModels"
             xmlns:c="using:ModelMeister.Ui.Controls"
             x:Class="ModelMeister.Ui.Views.ToolsView"
             x:DataType="vm:ToolsViewModel">

  <c:PageShell Eyebrow="SCAFFOLDING"
               Subtitle="Generate a typed model project from environment, JSON, or workbook"
               Status="{Binding StatusMessage}"
               IsBusy="{Binding Busy}">

    <Border Classes="card flush" Padding="0">
      <TabControl>

        <!-- ============== Tab 1 · From environment ============== -->
        <TabItem>
          <TabItem.Header>
            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
              <Path Data="{DynamicResource IcoEnvironments}" Width="14" Height="14" Stretch="Uniform"
                    Stroke="{Binding $parent[TabItem].Foreground}" StrokeThickness="1.5"
                    StrokeJoin="Round" StrokeLineCap="Round" Fill="Transparent" />
              <TextBlock Text="From environment" />
            </StackPanel>
          </TabItem.Header>

          <ScrollViewer Padding="22">
            <StackPanel Spacing="14" MaxWidth="900" HorizontalAlignment="Stretch">
              <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                <Border Width="36" Height="36" CornerRadius="9" Background="{DynamicResource AccentGlowFill}"
                        BorderBrush="{DynamicResource AccentDeep}" BorderThickness="1">
                  <Path Data="{DynamicResource IcoSpark}" Width="18" Height="18" Stretch="Uniform"
                        Fill="{DynamicResource Accent}"
                        HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <StackPanel Spacing="2">
                  <TextBlock Text="Scaffold C# model project from connected environment" FontSize="15" FontWeight="SemiBold" />
                  <TextBlock Text="Snapshots the live model via Remoting and emits a typed C# project — no intermediate JSON needed."
                             Classes="dim" />
                </StackPanel>
              </StackPanel>

              <Border Classes="cardSubtle">
                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                  <Ellipse Width="8" Height="8" Fill="{DynamicResource Success}" />
                  <TextBlock Text="Requires an active connection. See Environments → Connect." Classes="dim" />
                </StackPanel>
              </Border>

              <StackPanel Spacing="6">
                <TextBlock Text="OUTPUT DIRECTORY" Classes="label" />
                <Grid ColumnDefinitions="*,Auto">
                  <TextBox Text="{Binding EnvScaffoldOutputDir, Mode=TwoWay}" Classes="mono" Watermark="Output directory" />
                  <Button Grid.Column="1" Content="Browse" Command="{Binding BrowseEnvScaffoldOutCommand}" Margin="8,0,0,0" />
                </Grid>
              </StackPanel>

              <StackPanel Spacing="6">
                <TextBlock Text="ROOT NAMESPACE" Classes="label" />
                <TextBox Text="{Binding EnvScaffoldNamespace, Mode=TwoWay}" Watermark="Acme.PimModel" />
              </StackPanel>
              <StackPanel Orientation="Horizontal" Spacing="20">
                <CheckBox Content="Detect shared field-sets as abstract base classes"
                          IsChecked="{Binding EnvScaffoldDetectBaseClasses, Mode=TwoWay}" />
                <CheckBox Content="Skip CVL values (smaller project, faster build)"
                          IsChecked="{Binding EnvScaffoldNoCvlValues, Mode=TwoWay}" />
              </StackPanel>

              <StackPanel Orientation="Horizontal" Spacing="10">
                <Button Command="{Binding EnvScaffoldCommand}" Classes="primary">
                  <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Path Data="{DynamicResource IcoPlay}" Width="11" Height="11" Stretch="Uniform" Fill="{DynamicResource AccentButtonForeground}" />
                    <TextBlock Text="Scaffold from environment" />
                  </StackPanel>
                </Button>
                <Button Content="Cancel" Command="{Binding CancelCommand}" Classes="danger" IsEnabled="{Binding Busy}" />
              </StackPanel>

              <Border Classes="cardSubtle" IsVisible="{Binding EnvScaffoldDone}">
                <StackPanel Spacing="10">
                  <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <Ellipse Width="8" Height="8" Fill="{DynamicResource Success}" />
                    <TextBlock Text="Scaffold complete" FontWeight="SemiBold" />
                    <Border Classes="pill"
                            Background="{DynamicResource PillOkBg}"
                            BorderBrush="{DynamicResource Success}" BorderThickness="1" Padding="8,1">
                      <TextBlock FontSize="11" Foreground="{DynamicResource Success}">
                        <Run Text="{Binding EnvScaffoldFilesCount}" /> <Run Text="files" />
                      </TextBlock>
                    </Border>
                    <Border Classes="pill"
                            Background="{DynamicResource PillWarnBg}"
                            BorderBrush="{DynamicResource Warn}" BorderThickness="1" Padding="8,1"
                            IsVisible="{Binding EnvScaffoldWarnings.Count}">
                      <TextBlock FontSize="11" Foreground="{DynamicResource Warn}">
                        <Run Text="{Binding EnvScaffoldWarnings.Count}" /> <Run Text="warnings" />
                      </TextBlock>
                    </Border>
                    <Border Width="1" Background="{DynamicResource Border}" Margin="4,2" />
                    <Button Content="Open output folder" Classes="ghost" Command="{Binding OpenEnvScaffoldOutputCommand}" />
                  </StackPanel>
                  <Expander Header="Expression warnings"
                            IsVisible="{Binding EnvScaffoldWarnings.Count}">
                    <ItemsControl ItemsSource="{Binding EnvScaffoldWarnings}" MaxHeight="200">
                      <ItemsControl.Template>
                        <ControlTemplate>
                          <ScrollViewer><ItemsPresenter /></ScrollViewer>
                        </ControlTemplate>
                      </ItemsControl.Template>
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <Grid ColumnDefinitions="Auto,*" Margin="0,3">
                            <Ellipse Grid.Column="0" Width="5" Height="5" Margin="2,7,8,0" VerticalAlignment="Top"
                                     Fill="{DynamicResource Warn}" />
                            <TextBlock Grid.Column="1" Text="{Binding}" Classes="mono" FontSize="11" TextWrapping="Wrap" />
                          </Grid>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </Expander>
                </StackPanel>
              </Border>
            </StackPanel>
          </ScrollViewer>
        </TabItem>

        <!-- ============== Tab 2 · From JSON ============== -->
        <TabItem>
          <TabItem.Header>
            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
              <Path Data="{DynamicResource IcoModel}" Width="14" Height="14" Stretch="Uniform"
                    Stroke="{Binding $parent[TabItem].Foreground}" StrokeThickness="1.5"
                    StrokeJoin="Round" StrokeLineCap="Round" Fill="Transparent" />
              <TextBlock Text="From JSON" />
            </StackPanel>
          </TabItem.Header>

          <ScrollViewer Padding="22">
            <StackPanel Spacing="14" MaxWidth="900">
              <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                <Border Width="36" Height="36" CornerRadius="9" Background="{DynamicResource AccentGlowFill}"
                        BorderBrush="{DynamicResource AccentDeep}" BorderThickness="1">
                  <Path Data="{DynamicResource IcoModel}" Width="18" Height="18" Stretch="Uniform"
                        Stroke="{DynamicResource Accent}" StrokeThickness="1.5"
                        StrokeJoin="Round" StrokeLineCap="Round" Fill="Transparent"
                        HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <StackPanel Spacing="2">
                  <TextBlock Text="Scaffold C# model project from JSON export" FontSize="15" FontWeight="SemiBold" />
                  <TextBlock Text="Generate a typed model project mirroring an inriver export file." Classes="dim" />
                </StackPanel>
              </StackPanel>

              <StackPanel Spacing="6">
                <TextBlock Text="SOURCE JSON" Classes="label" />
                <Grid ColumnDefinitions="*,Auto">
                  <TextBox Text="{Binding ScaffoldJsonPath, Mode=TwoWay}" Classes="mono" Watermark="JSON export path" />
                  <Button Grid.Column="1" Content="Browse" Command="{Binding BrowseScaffoldJsonCommand}" Margin="8,0,0,0" />
                </Grid>
              </StackPanel>

              <StackPanel Spacing="6">
                <TextBlock Text="OUTPUT DIRECTORY" Classes="label" />
                <Grid ColumnDefinitions="*,Auto">
                  <TextBox Text="{Binding ScaffoldOutputDir, Mode=TwoWay}" Classes="mono" Watermark="Output directory" />
                  <Button Grid.Column="1" Content="Browse" Command="{Binding BrowseScaffoldOutCommand}" Margin="8,0,0,0" />
                </Grid>
              </StackPanel>

              <StackPanel Spacing="6">
                <TextBlock Text="ROOT NAMESPACE" Classes="label" />
                <TextBox Text="{Binding ScaffoldNamespace, Mode=TwoWay}" Watermark="Acme.PimModel" />
              </StackPanel>
              <StackPanel Orientation="Horizontal" Spacing="20">
                <CheckBox Content="Detect shared field-sets as abstract base classes"
                          IsChecked="{Binding ScaffoldDetectBaseClasses, Mode=TwoWay}" />
                <CheckBox Content="Skip CVL values (smaller project, faster build)"
                          IsChecked="{Binding ScaffoldNoCvlValues, Mode=TwoWay}" />
              </StackPanel>

              <StackPanel Orientation="Horizontal" Spacing="10">
                <Button Command="{Binding ScaffoldCommand}" Classes="primary">
                  <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Path Data="{DynamicResource IcoPlay}" Width="11" Height="11" Stretch="Uniform" Fill="{DynamicResource AccentButtonForeground}" />
                    <TextBlock Text="Scaffold from JSON" />
                  </StackPanel>
                </Button>
                <Button Content="Cancel" Command="{Binding CancelCommand}" Classes="danger" IsEnabled="{Binding Busy}" />
              </StackPanel>

              <Border Classes="cardSubtle" IsVisible="{Binding ScaffoldDone}">
                <StackPanel Spacing="10">
                  <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <Ellipse Width="8" Height="8" Fill="{DynamicResource Success}" />
                    <TextBlock Text="Scaffold complete" FontWeight="SemiBold" />
                    <Border Classes="pill"
                            Background="{DynamicResource PillOkBg}"
                            BorderBrush="{DynamicResource Success}" BorderThickness="1" Padding="8,1">
                      <TextBlock FontSize="11" Foreground="{DynamicResource Success}">
                        <Run Text="{Binding ScaffoldFilesCount}" /> <Run Text="files" />
                      </TextBlock>
                    </Border>
                    <Border Classes="pill"
                            Background="{DynamicResource PillWarnBg}"
                            BorderBrush="{DynamicResource Warn}" BorderThickness="1" Padding="8,1"
                            IsVisible="{Binding ScaffoldWarnings.Count}">
                      <TextBlock FontSize="11" Foreground="{DynamicResource Warn}">
                        <Run Text="{Binding ScaffoldWarnings.Count}" /> <Run Text="warnings" />
                      </TextBlock>
                    </Border>
                    <Border Width="1" Background="{DynamicResource Border}" Margin="4,2" />
                    <Button Content="Open output folder" Classes="ghost" Command="{Binding OpenScaffoldOutputCommand}" />
                  </StackPanel>
                  <Expander Header="Expression warnings"
                            IsVisible="{Binding ScaffoldWarnings.Count}">
                    <ItemsControl ItemsSource="{Binding ScaffoldWarnings}" MaxHeight="200">
                      <ItemsControl.Template>
                        <ControlTemplate>
                          <ScrollViewer><ItemsPresenter /></ScrollViewer>
                        </ControlTemplate>
                      </ItemsControl.Template>
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <Grid ColumnDefinitions="Auto,*" Margin="0,3">
                            <Ellipse Grid.Column="0" Width="5" Height="5" Margin="2,7,8,0" VerticalAlignment="Top"
                                     Fill="{DynamicResource Warn}" />
                            <TextBlock Grid.Column="1" Text="{Binding}" Classes="mono" FontSize="11" TextWrapping="Wrap" />
                          </Grid>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </Expander>
                </StackPanel>
              </Border>
            </StackPanel>
          </ScrollViewer>
        </TabItem>

        <!-- ============== Tab 3 · Merge JSONs ============== -->
        <TabItem>
          <TabItem.Header>
            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
              <Path Data="{DynamicResource IcoCompare}" Width="14" Height="14" Stretch="Uniform"
                    Stroke="{Binding $parent[TabItem].Foreground}" StrokeThickness="1.5"
                    StrokeJoin="Round" StrokeLineCap="Round" Fill="Transparent" />
              <TextBlock Text="Merge JSONs" />
            </StackPanel>
          </TabItem.Header>

          <ScrollViewer Padding="22">
            <StackPanel Spacing="14" MaxWidth="900">
              <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                <Border Width="36" Height="36" CornerRadius="9" Background="{DynamicResource AccentGlowFill}"
                        BorderBrush="{DynamicResource AccentDeep}" BorderThickness="1">
                  <Path Data="{DynamicResource IcoCompare}" Width="18" Height="18" Stretch="Uniform"
                        Stroke="{DynamicResource Accent}" StrokeThickness="1.5"
                        StrokeJoin="Round" StrokeLineCap="Round" Fill="Transparent"
                        HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <StackPanel Spacing="2">
                  <TextBlock Text="Merge two JSON exports" FontSize="15" FontWeight="SemiBold" />
                  <TextBlock Text="Combine base and overlay exports using a conflict policy." Classes="dim" />
                </StackPanel>
              </StackPanel>

              <StackPanel Spacing="6">
                <TextBlock Text="BASE JSON" Classes="label" />
                <Grid ColumnDefinitions="*,Auto">
                  <TextBox Text="{Binding MergeBasePath, Mode=TwoWay}" Classes="mono" Watermark="Base JSON" />
                  <Button Grid.Column="1" Content="Browse" Command="{Binding BrowseMergeBaseCommand}" Margin="8,0,0,0" />
                </Grid>
              </StackPanel>
              <StackPanel Spacing="6">
                <TextBlock Text="OVERLAY JSON" Classes="label" />
                <Grid ColumnDefinitions="*,Auto">
                  <TextBox Text="{Binding MergeOverlayPath, Mode=TwoWay}" Classes="mono" Watermark="Overlay JSON" />
                  <Button Grid.Column="1" Content="Browse" Command="{Binding BrowseMergeOverlayCommand}" Margin="8,0,0,0" />
                </Grid>
              </StackPanel>
              <StackPanel Spacing="6">
                <TextBlock Text="OUTPUT JSON (OPTIONAL)" Classes="label" />
                <Grid ColumnDefinitions="*,Auto">
                  <TextBox Text="{Binding MergeOutPath, Mode=TwoWay}" Classes="mono" Watermark="Output JSON (optional)" />
                  <Button Grid.Column="1" Content="Browse" Command="{Binding BrowseMergeOutCommand}" Margin="8,0,0,0" />
                </Grid>
              </StackPanel>

              <StackPanel Spacing="6">
                <TextBlock Text="CONFLICT POLICY" Classes="label" />
                <ComboBox ItemsSource="{Binding MergePolicies}" SelectedItem="{Binding MergePolicy, Mode=TwoWay}" MinWidth="220" HorizontalAlignment="Left" />
              </StackPanel>

              <StackPanel Orientation="Horizontal" Spacing="10">
                <Button Command="{Binding MergeCommand}" Classes="primary">
                  <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Path Data="{DynamicResource IcoPlay}" Width="11" Height="11" Stretch="Uniform" Fill="{DynamicResource AccentButtonForeground}" />
                    <TextBlock Text="Merge" />
                  </StackPanel>
                </Button>
                <Button Content="Cancel" Command="{Binding CancelCommand}" Classes="danger" IsEnabled="{Binding Busy}" />
              </StackPanel>

              <TextBox Text="{Binding MergeResultText, Mode=OneWay}" IsReadOnly="True"
                       Classes="mono"
                       AcceptsReturn="True" TextWrapping="Wrap" Height="140" />
            </StackPanel>
          </ScrollViewer>
        </TabItem>

        <!-- ============== Tab 4 · Export snapshot ============== -->
        <TabItem>
          <TabItem.Header>
            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
              <Path Data="{DynamicResource IcoFolder}" Width="14" Height="14" Stretch="Uniform"
                    Stroke="{Binding $parent[TabItem].Foreground}" StrokeThickness="1.5"
                    StrokeJoin="Round" StrokeLineCap="Round" Fill="Transparent" />
              <TextBlock Text="Export snapshot" />
            </StackPanel>
          </TabItem.Header>

          <ScrollViewer Padding="22">
            <StackPanel Spacing="14" MaxWidth="900">
              <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                <Border Width="36" Height="36" CornerRadius="9" Background="{DynamicResource AccentGlowFill}"
                        BorderBrush="{DynamicResource AccentDeep}" BorderThickness="1">
                  <Path Data="{DynamicResource IcoFolder}" Width="18" Height="18" Stretch="Uniform"
                        Stroke="{DynamicResource Accent}" StrokeThickness="1.5"
                        StrokeJoin="Round" StrokeLineCap="Round" Fill="Transparent"
                        HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <StackPanel Spacing="2">
                  <TextBlock Text="Export live environment to JSON" FontSize="15" FontWeight="SemiBold" />
                  <TextBlock Text="Capture the connected environment as a JSON snapshot." Classes="dim" />
                </StackPanel>
              </StackPanel>

              <StackPanel Spacing="6">
                <TextBlock Text="OUTPUT FILE" Classes="label" />
                <Grid ColumnDefinitions="*,Auto">
                  <TextBox Text="{Binding ExportOutputPath, Mode=TwoWay}" Classes="mono" Watermark="Snapshot output JSON" />
                  <Button Grid.Column="1" Content="Browse" Command="{Binding BrowseExportOutCommand}" Margin="8,0,0,0" />
                </Grid>
              </StackPanel>

              <StackPanel Orientation="Horizontal" Spacing="10">
                <Button Command="{Binding ExportCommand}" Classes="primary">
                  <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Path Data="{DynamicResource IcoPlay}" Width="11" Height="11" Stretch="Uniform" Fill="{DynamicResource AccentButtonForeground}" />
                    <TextBlock Text="Export snapshot" />
                  </StackPanel>
                </Button>
                <Button Content="Cancel" Command="{Binding CancelCommand}" Classes="danger" IsEnabled="{Binding Busy}" />
              </StackPanel>

              <TextBox Text="{Binding ExportResultText, Mode=OneWay}" IsReadOnly="True"
                       Classes="mono"
                       AcceptsReturn="True" TextWrapping="Wrap" Height="100" />
            </StackPanel>
          </ScrollViewer>
        </TabItem>

        <!-- ============== Tab 5 · Export Excel ============== -->
        <!-- Removed in Session 2: per-page PageActions own Excel export now. -->

        <!-- ============== Tab 5 · Scaffold from Excel ============== -->
        <TabItem>
          <TabItem.Header>
            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
              <Path Data="{DynamicResource IcoFolder}" Width="14" Height="14" Stretch="Uniform"
                    Stroke="{Binding $parent[TabItem].Foreground}" StrokeThickness="1.5"
                    StrokeJoin="Round" StrokeLineCap="Round" Fill="Transparent" />
              <TextBlock Text="From workbook" />
            </StackPanel>
          </TabItem.Header>

          <ScrollViewer Padding="22">
            <StackPanel Spacing="14" MaxWidth="900">
              <TextBlock Text="Generate a typed C# model project from an Excel workbook." Classes="dim" />
              <StackPanel Spacing="6">
                <TextBlock Text="WORKBOOK" Classes="label" />
                <Grid ColumnDefinitions="*,Auto">
                  <TextBox Text="{Binding ExcelScaffoldPath, Mode=TwoWay}" Classes="mono" Watermark="path\to\model.xlsx" />
                  <Button Grid.Column="1" Content="Browse" Command="{Binding BrowseExcelScaffoldXlsxCommand}" Margin="8,0,0,0" />
                </Grid>
              </StackPanel>
              <StackPanel Spacing="6">
                <TextBlock Text="OUTPUT DIRECTORY" Classes="label" />
                <Grid ColumnDefinitions="*,Auto">
                  <TextBox Text="{Binding ExcelScaffoldOutputDir, Mode=TwoWay}" Classes="mono" Watermark="Where to write the project" />
                  <Button Grid.Column="1" Content="Browse" Command="{Binding BrowseExcelScaffoldOutCommand}" Margin="8,0,0,0" />
                </Grid>
              </StackPanel>
              <StackPanel Spacing="6">
                <TextBlock Text="NAMESPACE" Classes="label" />
                <TextBox Text="{Binding ExcelScaffoldNamespace, Mode=TwoWay}" Classes="mono" />
              </StackPanel>
              <StackPanel Orientation="Horizontal" Spacing="20">
                <CheckBox Content="Detect shared field-sets as abstract base classes" IsChecked="{Binding ExcelScaffoldDetectBaseClasses, Mode=TwoWay}" />
                <CheckBox Content="Skip CVL values (smaller project, faster build)" IsChecked="{Binding ExcelScaffoldNoCvlValues, Mode=TwoWay}" />
              </StackPanel>
              <StackPanel Orientation="Horizontal" Spacing="10">
                <Button Content="Scaffold from workbook" Command="{Binding ExcelScaffoldCommand}" Classes="primary" IsEnabled="{Binding !Busy}" />
              </StackPanel>

              <Border Classes="cardSubtle" IsVisible="{Binding ExcelScaffoldDone}">
                <StackPanel Spacing="10">
                  <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <Ellipse Width="8" Height="8" Fill="{DynamicResource Success}" />
                    <TextBlock Text="Scaffold complete" FontWeight="SemiBold" />
                    <Border Classes="pill"
                            Background="{DynamicResource PillOkBg}"
                            BorderBrush="{DynamicResource Success}" BorderThickness="1" Padding="8,1">
                      <TextBlock FontSize="11" Foreground="{DynamicResource Success}">
                        <Run Text="{Binding ExcelScaffoldFilesCount}" /> <Run Text="files" />
                      </TextBlock>
                    </Border>
                    <Border Classes="pill"
                            Background="{DynamicResource PillWarnBg}"
                            BorderBrush="{DynamicResource Warn}" BorderThickness="1" Padding="8,1"
                            IsVisible="{Binding ExcelScaffoldWarnings.Count}">
                      <TextBlock FontSize="11" Foreground="{DynamicResource Warn}">
                        <Run Text="{Binding ExcelScaffoldWarnings.Count}" /> <Run Text="warnings" />
                      </TextBlock>
                    </Border>
                  </StackPanel>
                  <Expander Header="Expression warnings"
                            IsVisible="{Binding ExcelScaffoldWarnings.Count}">
                    <ItemsControl ItemsSource="{Binding ExcelScaffoldWarnings}" MaxHeight="200">
                      <ItemsControl.Template>
                        <ControlTemplate>
                          <ScrollViewer><ItemsPresenter /></ScrollViewer>
                        </ControlTemplate>
                      </ItemsControl.Template>
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <Grid ColumnDefinitions="Auto,*" Margin="0,3">
                            <Ellipse Grid.Column="0" Width="5" Height="5" Margin="2,7,8,0" VerticalAlignment="Top"
                                     Fill="{DynamicResource Warn}" />
                            <TextBlock Grid.Column="1" Text="{Binding}" Classes="mono" FontSize="11" TextWrapping="Wrap" />
                          </Grid>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </Expander>
                </StackPanel>
              </Border>
            </StackPanel>
          </ScrollViewer>
        </TabItem>

      </TabControl>
    </Border>

  </c:PageShell>
</UserControl>
