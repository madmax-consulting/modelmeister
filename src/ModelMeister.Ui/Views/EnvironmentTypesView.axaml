<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ModelMeister.Ui.ViewModels"
             xmlns:conv="using:ModelMeister.Ui.Converters"
             xmlns:m="using:ModelMeister.Ui.Models"
             xmlns:c="using:ModelMeister.Ui.Controls"
             x:Class="ModelMeister.Ui.Views.EnvironmentTypesView"
             x:DataType="vm:EnvironmentTypesViewModel"
             x:Name="PageRoot">

  <UserControl.Resources>
    <conv:HexToPillBrushConverter x:Key="PillBrush" />
  </UserControl.Resources>

  <c:PageShell Eyebrow="ENVIRONMENT TYPES"
               Subtitle="Color-coded classifications you assign to environments — double-click a row to edit"
               Status="{Binding Status}">
    <c:PageShell.Actions>
      <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
        <Button Classes="ghost icon" ToolTip.Tip="New environment type"
                Command="{Binding AddCommand}">
          <Path Data="{DynamicResource IcoPlus}" Width="13" Height="13" Stretch="Uniform"
                Stroke="{DynamicResource TextSec}" StrokeThickness="1.8"
                StrokeJoin="Round" StrokeLineCap="Round" Fill="Transparent" />
        </Button>
      </StackPanel>
    </c:PageShell.Actions>

    <Border Classes="card flush" Padding="0">
      <DockPanel LastChildFill="True">
        <c:GridToolbar DockPanel.Dock="Top" Margin="8,8,8,4" TargetGrid="{Binding #TypesGrid}" />
        <DataGrid Name="TypesGrid"
                  ItemsSource="{Binding Types}" IsReadOnly="True"
                  AutoGenerateColumns="False" SelectionMode="Single"
                  GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                  Margin="0" BorderThickness="0" CornerRadius="0">
          <DataGrid.ContextMenu>
            <ContextMenu>
              <MenuItem Header="Edit"
                        Command="{Binding EditCommand}"
                        CommandParameter="{Binding #TypesGrid.SelectedItem}" />
              <Separator />
              <MenuItem Header="Delete"
                        Command="{Binding DeleteCommand}"
                        CommandParameter="{Binding #TypesGrid.SelectedItem}" />
            </ContextMenu>
          </DataGrid.ContextMenu>
          <DataGrid.Columns>
            <DataGridTemplateColumn Width="110" CanUserSort="False">
              <DataGridTemplateColumn.Header>
                <TextBlock Text="Preview" Classes="colhead" />
              </DataGridTemplateColumn.Header>
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate x:DataType="m:EnvironmentType">
                  <Border Classes="stage" HorizontalAlignment="Left" VerticalAlignment="Center"
                          Background="{Binding ColorHex, Converter={StaticResource PillBrush}, ConverterParameter=soft}"
                          BorderBrush="{Binding ColorHex, Converter={StaticResource PillBrush}}">
                    <TextBlock Text="{Binding Shorthand}"
                               Foreground="{Binding ColorHex, Converter={StaticResource PillBrush}}" />
                  </Border>
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>

            <DataGridTextColumn Binding="{Binding Name}" Width="*" MinWidth="140">
              <DataGridTextColumn.Header><c:FilterableHeader Title="Name" Path="Name" /></DataGridTextColumn.Header>
            </DataGridTextColumn>
            <DataGridTextColumn Binding="{Binding Shorthand}" Width="120" MinWidth="90">
              <DataGridTextColumn.Header><c:FilterableHeader Title="Shorthand" Path="Shorthand" /></DataGridTextColumn.Header>
            </DataGridTextColumn>
            <DataGridTextColumn Binding="{Binding Description}" Width="2*" MinWidth="180">
              <DataGridTextColumn.Header><c:FilterableHeader Title="Description" Path="Description" /></DataGridTextColumn.Header>
            </DataGridTextColumn>

            <DataGridTemplateColumn Width="90" CanUserSort="False">
              <DataGridTemplateColumn.Header>
                <TextBlock Text="Protected" Classes="colhead" HorizontalAlignment="Center" />
              </DataGridTemplateColumn.Header>
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate x:DataType="m:EnvironmentType">
                  <CheckBox IsChecked="{Binding IsProtected}" IsHitTestVisible="False"
                            HorizontalAlignment="Center" VerticalAlignment="Center"
                            ToolTip.Tip="Shows the red safety banner before destructive operations" />
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>

            <DataGridTemplateColumn Width="90" CanUserSort="False">
              <DataGridTemplateColumn.Header>
                <TextBlock Text="Origin" Classes="colhead" />
              </DataGridTemplateColumn.Header>
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate x:DataType="m:EnvironmentType">
                  <Grid VerticalAlignment="Center">
                    <TextBlock Text="Built-in" Classes="dim" IsVisible="{Binding IsBuiltIn}" />
                    <TextBlock Text="Custom"   IsVisible="{Binding !IsBuiltIn}" />
                  </Grid>
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>

            <DataGridTemplateColumn Header="" Width="100">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate x:DataType="m:EnvironmentType">
                  <StackPanel Orientation="Horizontal" Spacing="3" Margin="4,0">
                    <Button Classes="ghost icon" Padding="6" ToolTip.Tip="Edit"
                            Command="{Binding $parent[DataGrid].((vm:EnvironmentTypesViewModel)DataContext).EditCommand}"
                            CommandParameter="{Binding}">
                      <Path Data="{DynamicResource IcoEdit}" Width="12" Height="12" Stretch="Uniform"
                            Stroke="{DynamicResource TextSec}" StrokeThickness="1.6" Fill="Transparent" />
                    </Button>
                    <Button Classes="ghost icon danger" Padding="6" ToolTip.Tip="Delete"
                            Command="{Binding $parent[DataGrid].((vm:EnvironmentTypesViewModel)DataContext).DeleteCommand}"
                            CommandParameter="{Binding}">
                      <Path Data="{DynamicResource IcoTrash}" Width="12" Height="12" Stretch="Uniform"
                            Stroke="{DynamicResource Danger}" StrokeThickness="1.6" Fill="Transparent" />
                    </Button>
                  </StackPanel>
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>
          </DataGrid.Columns>
        </DataGrid>
      </DockPanel>
    </Border>

  </c:PageShell>
</UserControl>
