<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ModelMeister.Ui.ViewModels"
             xmlns:m="using:ModelMeister.Ui.Models"
             xmlns:c="using:ModelMeister.Ui.Controls"
             xmlns:conv="using:ModelMeister.Ui.Converters"
             xmlns:svc="using:ModelMeister.Ui.Services"
             xmlns:views="using:ModelMeister.Ui.Views"
             x:Class="ModelMeister.Ui.Views.ServerSettingsCompareView"
             x:DataType="vm:ServerSettingsCompareViewModel"
             x:Name="Root">

  <UserControl.Resources>
    <conv:StageToBrushConverter x:Key="StageBrush" />
    <conv:StageToTextConverter x:Key="StageText" />
  </UserControl.Resources>

  <!-- The CompareLayoutView already supplies a full PageShell (eyebrow/subtitle/status). Wrapping it
       in another DockPanel + status strip would stack two headers; let the layout own the chrome. -->
  <views:CompareLayoutView Eyebrow="SERVER SETTINGS · COMPARE"
                           Subtitle="Compare server settings across two environments — promote per-key">
    <views:CompareLayoutView.Body>
      <DockPanel LastChildFill="True">
        <c:GridToolbar DockPanel.Dock="Top" Margin="2,0,0,8" TargetGrid="{Binding #MainGrid}" />
        <DataGrid Name="MainGrid" ItemsSource="{Binding Rows}" IsReadOnly="True"
                  AutoGenerateColumns="False" SelectionMode="Extended"
                  svc:GridSelectionBehavior.Selection="{Binding Selection}"
                  GridLinesVisibility="Horizontal" HeadersVisibility="Column" Classes="filterable fit">
          <DataGrid.Columns>
            <DataGridTemplateColumn Width="40" CanUserResize="False" CanUserReorder="False" CanUserSort="False"
                                    CellTemplate="{StaticResource RowSelectCell}">
              <DataGridTemplateColumn.Header>
                <CheckBox IsChecked="{Binding #Root.((vm:ServerSettingsCompareViewModel)DataContext).Selection.AllSelected, Mode=TwoWay}"
                          HorizontalAlignment="Center" VerticalAlignment="Center" ToolTip.Tip="Select all" />
              </DataGridTemplateColumn.Header>
            </DataGridTemplateColumn>
            <!-- Which environment(s) the key exists in, as named stage pills — replaces only-left/only-right text. -->
            <DataGridTemplateColumn Header="Environment" Width="150" MinWidth="120">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate x:DataType="vm:ServerSettingRow">
                  <StackPanel Orientation="Horizontal" Spacing="3" VerticalAlignment="Center">
                    <Border Classes="pill" IsVisible="{Binding InLeft}"
                            Background="{Binding $parent[DataGrid].((vm:ServerSettingsCompareViewModel)DataContext).LeftColumnStage, Converter={StaticResource StageBrush}, ConverterParameter=soft}"
                            BorderBrush="{Binding $parent[DataGrid].((vm:ServerSettingsCompareViewModel)DataContext).LeftColumnStage, Converter={StaticResource StageBrush}}"
                            BorderThickness="1" Padding="7,0">
                      <TextBlock Text="{Binding $parent[DataGrid].((vm:ServerSettingsCompareViewModel)DataContext).LeftColumnHeader}"
                                 Foreground="{Binding $parent[DataGrid].((vm:ServerSettingsCompareViewModel)DataContext).LeftColumnStage, Converter={StaticResource StageBrush}}"
                                 FontSize="10" FontWeight="SemiBold" />
                    </Border>
                    <Border Classes="pill" IsVisible="{Binding InRight}"
                            Background="{Binding $parent[DataGrid].((vm:ServerSettingsCompareViewModel)DataContext).RightColumnStage, Converter={StaticResource StageBrush}, ConverterParameter=soft}"
                            BorderBrush="{Binding $parent[DataGrid].((vm:ServerSettingsCompareViewModel)DataContext).RightColumnStage, Converter={StaticResource StageBrush}}"
                            BorderThickness="1" Padding="7,0">
                      <TextBlock Text="{Binding $parent[DataGrid].((vm:ServerSettingsCompareViewModel)DataContext).RightColumnHeader}"
                                 Foreground="{Binding $parent[DataGrid].((vm:ServerSettingsCompareViewModel)DataContext).RightColumnStage, Converter={StaticResource StageBrush}}"
                                 FontSize="10" FontWeight="SemiBold" />
                    </Border>
                  </StackPanel>
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>
            <DataGridTextColumn Binding="{Binding Key}" Width="1.2*" MinWidth="120">
              <DataGridTextColumn.Header><c:FilterableHeader Title="Key" Path="Key" /></DataGridTextColumn.Header>
            </DataGridTextColumn>

            <DataGridTemplateColumn Width="1.4*" MinWidth="90" CanUserSort="True" SortMemberPath="LeftDisplay">
              <DataGridTemplateColumn.Header>
                <c:FilterableHeader Path="LeftDisplay">
                  <c:FilterableHeader.Title>
                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                      <TextBlock Text="{Binding #Root.((vm:ServerSettingsCompareViewModel)DataContext).LeftColumnHeader}" />
                      <Border Classes="pill"
                              Background="{Binding #Root.((vm:ServerSettingsCompareViewModel)DataContext).LeftColumnStage, Converter={StaticResource StageBrush}, ConverterParameter=soft}"
                              BorderBrush="{Binding #Root.((vm:ServerSettingsCompareViewModel)DataContext).LeftColumnStage, Converter={StaticResource StageBrush}}"
                              BorderThickness="1" Padding="5,0">
                        <TextBlock Text="{Binding #Root.((vm:ServerSettingsCompareViewModel)DataContext).LeftColumnStage, Converter={StaticResource StageText}}"
                                   Foreground="{Binding #Root.((vm:ServerSettingsCompareViewModel)DataContext).LeftColumnStage, Converter={StaticResource StageBrush}}"
                                   FontSize="9" FontWeight="SemiBold" />
                      </Border>
                    </StackPanel>
                  </c:FilterableHeader.Title>
                </c:FilterableHeader>
              </DataGridTemplateColumn.Header>
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate x:DataType="vm:ServerSettingRow">
                  <TextBlock Text="{Binding LeftDisplay}" VerticalAlignment="Center" Margin="8,0" />
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>

            <DataGridTemplateColumn Width="1.4*" MinWidth="90" CanUserSort="True" SortMemberPath="RightDisplay">
              <DataGridTemplateColumn.Header>
                <c:FilterableHeader Path="RightDisplay">
                  <c:FilterableHeader.Title>
                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                      <TextBlock Text="{Binding #Root.((vm:ServerSettingsCompareViewModel)DataContext).RightColumnHeader}" />
                      <Border Classes="pill"
                              Background="{Binding #Root.((vm:ServerSettingsCompareViewModel)DataContext).RightColumnStage, Converter={StaticResource StageBrush}, ConverterParameter=soft}"
                              BorderBrush="{Binding #Root.((vm:ServerSettingsCompareViewModel)DataContext).RightColumnStage, Converter={StaticResource StageBrush}}"
                              BorderThickness="1" Padding="5,0">
                        <TextBlock Text="{Binding #Root.((vm:ServerSettingsCompareViewModel)DataContext).RightColumnStage, Converter={StaticResource StageText}}"
                                   Foreground="{Binding #Root.((vm:ServerSettingsCompareViewModel)DataContext).RightColumnStage, Converter={StaticResource StageBrush}}"
                                   FontSize="9" FontWeight="SemiBold" />
                      </Border>
                    </StackPanel>
                  </c:FilterableHeader.Title>
                </c:FilterableHeader>
              </DataGridTemplateColumn.Header>
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate x:DataType="vm:ServerSettingRow">
                  <TextBlock Text="{Binding RightDisplay}" VerticalAlignment="Center" Margin="8,0" />
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>

            <!-- Per-row apply (one-way: source → target). Direction is shown as source→target stage
                 pills (e.g. [DEV]→[PROD]). Swap the environments to apply the other direction. -->
            <DataGridTemplateColumn Header="Promote" Width="150" MinWidth="140">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate x:DataType="vm:ServerSettingRow">
                  <StackPanel Orientation="Horizontal" Spacing="6" Margin="4,0">
                    <Button Classes="ghost" Padding="4,2"
                            ToolTip.Tip="Apply left value to right environment"
                            Command="{Binding $parent[DataGrid].((vm:ServerSettingsCompareViewModel)DataContext).ApplyLeftToRightCommand}"
                            CommandParameter="{Binding}">
                      <StackPanel Orientation="Horizontal" Spacing="3" VerticalAlignment="Center">
                        <Border Classes="pill"
                                Background="{Binding $parent[DataGrid].((vm:ServerSettingsCompareViewModel)DataContext).LeftColumnStage, Converter={StaticResource StageBrush}, ConverterParameter=soft}"
                                BorderBrush="{Binding $parent[DataGrid].((vm:ServerSettingsCompareViewModel)DataContext).LeftColumnStage, Converter={StaticResource StageBrush}}"
                                BorderThickness="1" Padding="4,0">
                          <TextBlock Text="{Binding $parent[DataGrid].((vm:ServerSettingsCompareViewModel)DataContext).LeftColumnStage, Converter={StaticResource StageText}}"
                                     Foreground="{Binding $parent[DataGrid].((vm:ServerSettingsCompareViewModel)DataContext).LeftColumnStage, Converter={StaticResource StageBrush}}"
                                     FontSize="9" FontWeight="SemiBold" />
                        </Border>
                        <TextBlock Text="→" VerticalAlignment="Center" />
                        <Border Classes="pill"
                                Background="{Binding $parent[DataGrid].((vm:ServerSettingsCompareViewModel)DataContext).RightColumnStage, Converter={StaticResource StageBrush}, ConverterParameter=soft}"
                                BorderBrush="{Binding $parent[DataGrid].((vm:ServerSettingsCompareViewModel)DataContext).RightColumnStage, Converter={StaticResource StageBrush}}"
                                BorderThickness="1" Padding="4,0">
                          <TextBlock Text="{Binding $parent[DataGrid].((vm:ServerSettingsCompareViewModel)DataContext).RightColumnStage, Converter={StaticResource StageText}}"
                                     Foreground="{Binding $parent[DataGrid].((vm:ServerSettingsCompareViewModel)DataContext).RightColumnStage, Converter={StaticResource StageBrush}}"
                                     FontSize="9" FontWeight="SemiBold" />
                        </Border>
                      </StackPanel>
                    </Button>
                  </StackPanel>
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>
          </DataGrid.Columns>
        </DataGrid>
      </DockPanel>
    </views:CompareLayoutView.Body>
  </views:CompareLayoutView>
</UserControl>
