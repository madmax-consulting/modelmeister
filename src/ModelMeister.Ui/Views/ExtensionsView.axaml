<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ModelMeister.Ui.ViewModels"
             xmlns:svc="using:ModelMeister.Ui.Services"
             xmlns:c="using:ModelMeister.Ui.Controls"
             x:Class="ModelMeister.Ui.Views.ExtensionsView"
             x:DataType="vm:ExtensionsViewModel"
             x:Name="PageRoot">

  <UserControl.KeyBindings>
    <KeyBinding Gesture="Delete" Command="{Binding DeleteSelectedExtensionsCommand}" />
    <KeyBinding Gesture="Escape" Command="{Binding ItemsSelection.ClearCommand}" />
    <KeyBinding Gesture="Ctrl+A" Command="{Binding ItemsSelection.SelectAllVisibleCommand}" />
  </UserControl.KeyBindings>

  <c:PageShell Eyebrow="EXTENSIONS"
               Subtitle="Extensions registered on the connected environment — settings, events, states"
               Status="{Binding StatusMessage}"
               IsBusy="{Binding Busy}">
    <c:PageShell.Actions>
      <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
        <Button Classes="ghost icon danger" ToolTip.Tip="Delete selected extensions"
                Command="{Binding DeleteSelectedExtensionsCommand}"
                IsVisible="{Binding ItemsSelection.HasSelection}">
          <Path Data="{DynamicResource IcoTrash}" Width="13" Height="13" Stretch="Uniform"
                Stroke="{DynamicResource Danger}" StrokeThickness="1.6"
                StrokeJoin="Round" StrokeLineCap="Round" Fill="Transparent" />
        </Button>
        <Button Content="Latest events" Command="{Binding RefreshAllEventsCommand}"
                Classes="ghost" IsEnabled="{Binding !Busy}" />
        <c:PageActions DataContext="{Binding}" />
      </StackPanel>
    </c:PageShell.Actions>

    <!-- Master/detail split inside a single card -->
    <Border Classes="card flush" Padding="0">
      <Grid ColumnDefinitions="*,1,1.4*">

        <!-- Left: extensions list -->
        <DockPanel Grid.Column="0" LastChildFill="True">
        <c:GridToolbar DockPanel.Dock="Top" Margin="8,8,8,4" TargetGrid="{Binding #ExtensionsGrid}" />
        <DataGrid Name="ExtensionsGrid"
                  ItemsSource="{Binding Items}"
                  SelectedItem="{Binding Selected, Mode=TwoWay}"
                  IsReadOnly="True"
                  AutoGenerateColumns="False"
                  SelectionMode="Single"
                  Margin="0" BorderThickness="0" CornerRadius="0"
                  svc:GridSelectionBehavior.Selection="{Binding ItemsSelection}">
          <DataGrid.ContextMenu>
            <ContextMenu>
              <MenuItem Header="Start"
                        Command="{Binding StartCommand}"
                        CommandParameter="{Binding #ExtensionsGrid.SelectedItem}" />
              <MenuItem Header="Stop"
                        Command="{Binding StopCommand}"
                        CommandParameter="{Binding #ExtensionsGrid.SelectedItem}" />
              <MenuItem Header="Run now (REST)"
                        Command="{Binding RunCommand}"
                        CommandParameter="{Binding #ExtensionsGrid.SelectedItem}" />
              <Separator />
              <MenuItem Header="View events"
                        Command="{Binding ViewEventsCommand}"
                        CommandParameter="{Binding #ExtensionsGrid.SelectedItem}" />
              <MenuItem Header="Load states"
                        Command="{Binding LoadStatesCommand}"
                        CommandParameter="{Binding #ExtensionsGrid.SelectedItem}" />
              <Separator />
              <MenuItem Header="Copy id"
                        Command="{Binding CopyExtensionIdCommand}"
                        CommandParameter="{Binding #ExtensionsGrid.SelectedItem}" />
              <MenuItem Header="Copy type"
                        Command="{Binding CopyExtensionTypeCommand}"
                        CommandParameter="{Binding #ExtensionsGrid.SelectedItem}" />
              <Separator />
              <MenuItem Header="Delete"
                        Command="{Binding DeleteExtensionCommand}"
                        CommandParameter="{Binding #ExtensionsGrid.SelectedItem}" />
              <MenuItem Header="Delete selected"
                        Command="{Binding DeleteSelectedExtensionsCommand}"
                        IsEnabled="{Binding ItemsSelection.HasSelection}" />
            </ContextMenu>
          </DataGrid.ContextMenu>
          <DataGrid.Columns>
            <DataGridTemplateColumn Width="40" CanUserResize="False" CanUserReorder="False" CanUserSort="False"
                                    CellTemplate="{StaticResource RowSelectCell}">
              <DataGridTemplateColumn.Header>
                <CheckBox IsChecked="{Binding #PageRoot.((vm:ExtensionsViewModel)DataContext).ItemsSelection.AllSelected, Mode=TwoWay}"
                          HorizontalAlignment="Center" VerticalAlignment="Center" ToolTip.Tip="Select all" />
              </DataGridTemplateColumn.Header>
            </DataGridTemplateColumn>
            <DataGridTextColumn Binding="{Binding Id}" Width="*" MinWidth="120">
              <DataGridTextColumn.Header><c:FilterableHeader Title="Id" Path="Id" /></DataGridTextColumn.Header>
            </DataGridTextColumn>
            <DataGridTextColumn Binding="{Binding TypeName}" Width="*" MinWidth="120">
              <DataGridTextColumn.Header><c:FilterableHeader Title="Type" Path="TypeName" /></DataGridTextColumn.Header>
            </DataGridTextColumn>
            <DataGridTextColumn Binding="{Binding Status}" Width="70" MinWidth="60">
              <DataGridTextColumn.Header><c:FilterableHeader Title="Status" Path="Status" /></DataGridTextColumn.Header>
            </DataGridTextColumn>
            <DataGridTextColumn Binding="{Binding RecentErrorCount}" Width="50" MinWidth="50">
              <DataGridTextColumn.Header><c:FilterableHeader Title="Errs" Path="RecentErrorCount" /></DataGridTextColumn.Header>
            </DataGridTextColumn>
            <DataGridTemplateColumn Header="" Width="150">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate x:DataType="vm:ExtensionRow">
                  <StackPanel Orientation="Horizontal" Spacing="3" Margin="4,0">
                    <Button Content="▶" Classes="ghost" Padding="6,2" MinHeight="22"
                            ToolTip.Tip="Start"
                            Command="{Binding $parent[DataGrid].((vm:ExtensionsViewModel)DataContext).StartCommand}"
                            CommandParameter="{Binding}"
                            IsVisible="{Binding !IsStarted}" />
                    <Button Content="◼" Classes="ghost danger" Padding="6,2" MinHeight="22"
                            ToolTip.Tip="Stop"
                            Command="{Binding $parent[DataGrid].((vm:ExtensionsViewModel)DataContext).StopCommand}"
                            CommandParameter="{Binding}"
                            IsVisible="{Binding IsStarted}" />
                    <Button Content="↻" Classes="ghost" Padding="6,2" MinHeight="22"
                            ToolTip.Tip="Run (REST :run)"
                            Command="{Binding $parent[DataGrid].((vm:ExtensionsViewModel)DataContext).RunCommand}"
                            CommandParameter="{Binding}"
                            IsEnabled="{Binding $parent[DataGrid].((vm:ExtensionsViewModel)DataContext).HasRestKey}" />
                    <Button Classes="ghost icon danger" Padding="6" MinHeight="22" ToolTip.Tip="Delete extension"
                            Command="{Binding $parent[DataGrid].((vm:ExtensionsViewModel)DataContext).DeleteExtensionCommand}"
                            CommandParameter="{Binding}">
                      <Path Data="{DynamicResource IcoTrash}" Width="11" Height="11" Stretch="Uniform"
                            Stroke="{DynamicResource Danger}" StrokeThickness="1.6" Fill="Transparent" />
                    </Button>
                  </StackPanel>
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>
          </DataGrid.Columns>
        </DataGrid>
        </DockPanel>

        <!-- Vertical divider -->
        <Border Grid.Column="1" Background="{DynamicResource Border}" Width="1" />

        <!-- Right: detail tabs (slim) -->
        <TabControl Grid.Column="2" Padding="0">
          <TabItem Header="Settings">
            <Grid RowDefinitions="Auto,*,Auto" Margin="6">
              <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,4">
                <c:GridToolbar Grid.Column="0" TargetGrid="{Binding #SettingsGrid}" />
                <Button Grid.Column="1" Classes="ghost danger" Padding="8,3" Content="Delete selected"
                        Command="{Binding DeleteSelectedSettingsCommand}"
                        IsVisible="{Binding SettingsSelection.HasSelection}" />
              </Grid>
              <DataGrid Grid.Row="1" Name="SettingsGrid" ItemsSource="{Binding Settings}" IsReadOnly="True"
                        AutoGenerateColumns="False" SelectionMode="Single" BorderThickness="1"
                        svc:GridSelectionBehavior.Selection="{Binding SettingsSelection}">
                <DataGrid.Columns>
                  <DataGridTemplateColumn Width="40" CanUserResize="False" CanUserReorder="False" CanUserSort="False"
                                          CellTemplate="{StaticResource RowSelectCell}">
                    <DataGridTemplateColumn.Header>
                      <CheckBox IsChecked="{Binding #PageRoot.((vm:ExtensionsViewModel)DataContext).SettingsSelection.AllSelected, Mode=TwoWay}"
                                HorizontalAlignment="Center" VerticalAlignment="Center" ToolTip.Tip="Select all" />
                    </DataGridTemplateColumn.Header>
                  </DataGridTemplateColumn>
                  <DataGridTextColumn Binding="{Binding Key}" Width="200" MinWidth="120">
                    <DataGridTextColumn.Header><c:FilterableHeader Title="Key" Path="Key" /></DataGridTextColumn.Header>
                  </DataGridTextColumn>
                  <DataGridTextColumn Binding="{Binding Value}" Width="*" MinWidth="120">
                    <DataGridTextColumn.Header><c:FilterableHeader Title="Value" Path="Value" /></DataGridTextColumn.Header>
                  </DataGridTextColumn>
                  <DataGridTemplateColumn Header="" Width="74">
                    <DataGridTemplateColumn.CellTemplate>
                      <DataTemplate x:DataType="vm:ExtensionSettingRow">
                        <StackPanel Orientation="Horizontal" Spacing="2">
                          <Button Classes="ghost icon" Padding="6" MinHeight="22" ToolTip.Tip="Edit value"
                                  Command="{Binding $parent[DataGrid].((vm:ExtensionsViewModel)DataContext).EditSettingCommand}"
                                  CommandParameter="{Binding}">
                            <Path Data="{DynamicResource IcoEdit}" Width="11" Height="11" Stretch="Uniform"
                                  Stroke="{DynamicResource TextSec}" StrokeThickness="1.6" Fill="Transparent" />
                          </Button>
                          <Button Classes="ghost icon danger" Padding="6" MinHeight="22" ToolTip.Tip="Delete setting"
                                  Command="{Binding $parent[DataGrid].((vm:ExtensionsViewModel)DataContext).DeleteSettingCommand}"
                                  CommandParameter="{Binding}">
                            <Path Data="{DynamicResource IcoTrash}" Width="11" Height="11" Stretch="Uniform"
                                  Stroke="{DynamicResource Danger}" StrokeThickness="1.6" Fill="Transparent" />
                          </Button>
                        </StackPanel>
                      </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                  </DataGridTemplateColumn>
                </DataGrid.Columns>
              </DataGrid>
              <Grid Grid.Row="2" Margin="0,6,0,0" ColumnDefinitions="*,1.5*,Auto">
                <TextBox Grid.Column="0" Text="{Binding NewSettingKey, Mode=TwoWay}" Watermark="key" />
                <TextBox Grid.Column="1" Text="{Binding NewSettingValue, Mode=TwoWay}" Watermark="value" Margin="6,0,0,0" />
                <Button Grid.Column="2" Content="Save" Command="{Binding AddSettingCommand}"
                        Classes="primary" IsEnabled="{Binding !Busy}" Margin="6,0,0,0" />
              </Grid>
            </Grid>
          </TabItem>

          <TabItem Header="Events">
            <DockPanel LastChildFill="True" Margin="6">
            <c:GridToolbar DockPanel.Dock="Top" Margin="0,0,0,4" TargetGrid="{Binding #EventsGrid}" />
            <DataGrid Name="EventsGrid" ItemsSource="{Binding Events}" IsReadOnly="True"
                      AutoGenerateColumns="False" BorderThickness="1">
              <DataGrid.Columns>
                <DataGridTextColumn Binding="{Binding Utc}" Width="160" MinWidth="120">
                  <DataGridTextColumn.Header><c:FilterableHeader Title="UTC" Path="Utc" /></DataGridTextColumn.Header>
                </DataGridTextColumn>
                <DataGridTextColumn Binding="{Binding Severity}" Width="64" MinWidth="56">
                  <DataGridTextColumn.Header><c:FilterableHeader Title="Level" Path="Severity" /></DataGridTextColumn.Header>
                </DataGridTextColumn>
                <DataGridTextColumn Binding="{Binding Message}" Width="*" MinWidth="160">
                  <DataGridTextColumn.Header><c:FilterableHeader Title="Message" Path="Message" /></DataGridTextColumn.Header>
                </DataGridTextColumn>
              </DataGrid.Columns>
            </DataGrid>
            </DockPanel>
          </TabItem>

          <TabItem Header="States">
            <Grid RowDefinitions="Auto,*,Auto" Margin="6">
              <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,4">
                <c:GridToolbar Grid.Column="0" TargetGrid="{Binding #StatesGrid}" />
                <Button Grid.Column="1" Classes="ghost danger" Padding="8,3" Content="Delete selected"
                        Command="{Binding DeleteSelectedStatesCommand}"
                        IsVisible="{Binding StatesSelection.HasSelection}" />
              </Grid>
              <DataGrid Grid.Row="1" Name="StatesGrid" ItemsSource="{Binding States}" IsReadOnly="True"
                        AutoGenerateColumns="False" BorderThickness="1"
                        svc:GridSelectionBehavior.Selection="{Binding StatesSelection}">
                <DataGrid.Columns>
                  <DataGridTemplateColumn Width="40" CanUserResize="False" CanUserReorder="False" CanUserSort="False"
                                          CellTemplate="{StaticResource RowSelectCell}">
                    <DataGridTemplateColumn.Header>
                      <CheckBox IsChecked="{Binding #PageRoot.((vm:ExtensionsViewModel)DataContext).StatesSelection.AllSelected, Mode=TwoWay}"
                                HorizontalAlignment="Center" VerticalAlignment="Center" ToolTip.Tip="Select all" />
                    </DataGridTemplateColumn.Header>
                  </DataGridTemplateColumn>
                  <DataGridTextColumn Binding="{Binding Id}" Width="50" MinWidth="50">
                    <DataGridTextColumn.Header><c:FilterableHeader Title="Id" Path="Id" /></DataGridTextColumn.Header>
                  </DataGridTextColumn>
                  <DataGridTextColumn Binding="{Binding ModifiedUtc}" Width="160" MinWidth="120">
                    <DataGridTextColumn.Header><c:FilterableHeader Title="Modified" Path="ModifiedUtc" /></DataGridTextColumn.Header>
                  </DataGridTextColumn>
                  <DataGridTextColumn Binding="{Binding Data}" Width="*" MinWidth="160">
                    <DataGridTextColumn.Header><c:FilterableHeader Title="Data" Path="Data" /></DataGridTextColumn.Header>
                  </DataGridTextColumn>
                  <DataGridTemplateColumn Header="" Width="74">
                    <DataGridTemplateColumn.CellTemplate>
                      <DataTemplate x:DataType="vm:ExtensionStateRowVm">
                        <StackPanel Orientation="Horizontal" Spacing="2">
                          <Button Classes="ghost icon" Padding="6" MinHeight="22" ToolTip.Tip="Edit state data"
                                  Command="{Binding $parent[DataGrid].((vm:ExtensionsViewModel)DataContext).EditStateCommand}"
                                  CommandParameter="{Binding}">
                            <Path Data="{DynamicResource IcoEdit}" Width="11" Height="11" Stretch="Uniform"
                                  Stroke="{DynamicResource TextSec}" StrokeThickness="1.6" Fill="Transparent" />
                          </Button>
                          <Button Classes="ghost icon danger" Padding="6" MinHeight="22" ToolTip.Tip="Delete state"
                                  Command="{Binding $parent[DataGrid].((vm:ExtensionsViewModel)DataContext).DeleteStateCommand}"
                                  CommandParameter="{Binding}">
                            <Path Data="{DynamicResource IcoTrash}" Width="11" Height="11" Stretch="Uniform"
                                  Stroke="{DynamicResource Danger}" StrokeThickness="1.6" Fill="Transparent" />
                          </Button>
                        </StackPanel>
                      </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                  </DataGridTemplateColumn>
                </DataGrid.Columns>
              </DataGrid>
              <Grid Grid.Row="2" Margin="0,6,0,0" ColumnDefinitions="*,Auto">
                <TextBox Grid.Column="0" Text="{Binding NewStateData, Mode=TwoWay}" Watermark="state data" />
                <Button Grid.Column="1" Content="Add" Command="{Binding AddStateCommand}"
                        Classes="primary" IsEnabled="{Binding !Busy}" Margin="6,0,0,0" />
              </Grid>
            </Grid>
          </TabItem>

          <TabItem Header="Latest (all)">
            <DockPanel LastChildFill="True" Margin="6">
            <c:GridToolbar DockPanel.Dock="Top" Margin="0,0,0,4" TargetGrid="{Binding #LatestEventsGrid}" />
            <DataGrid Name="LatestEventsGrid" ItemsSource="{Binding AllEvents}" IsReadOnly="True"
                      AutoGenerateColumns="False" BorderThickness="1">
              <DataGrid.Columns>
                <DataGridTextColumn Binding="{Binding Utc}" Width="160" MinWidth="120">
                  <DataGridTextColumn.Header><c:FilterableHeader Title="UTC" Path="Utc" /></DataGridTextColumn.Header>
                </DataGridTextColumn>
                <DataGridTextColumn Binding="{Binding ConnectorId}" Width="160" MinWidth="120">
                  <DataGridTextColumn.Header><c:FilterableHeader Title="Extension" Path="ConnectorId" /></DataGridTextColumn.Header>
                </DataGridTextColumn>
                <DataGridTextColumn Binding="{Binding Severity}" Width="56" MinWidth="50">
                  <DataGridTextColumn.Header><c:FilterableHeader Title="Lvl" Path="Severity" /></DataGridTextColumn.Header>
                </DataGridTextColumn>
                <DataGridTextColumn Binding="{Binding Message}" Width="*" MinWidth="160">
                  <DataGridTextColumn.Header><c:FilterableHeader Title="Message" Path="Message" /></DataGridTextColumn.Header>
                </DataGridTextColumn>
              </DataGrid.Columns>
            </DataGrid>
            </DockPanel>
          </TabItem>
        </TabControl>
      </Grid>
    </Border>

  </c:PageShell>
</UserControl>
