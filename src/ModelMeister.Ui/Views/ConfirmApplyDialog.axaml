<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ModelMeister.Ui.ViewModels"
        xmlns:conv="using:ModelMeister.Ui.Converters"
        x:Class="ModelMeister.Ui.Views.ConfirmApplyDialog"
        x:DataType="vm:ConfirmApplyViewModel"
        Title="Confirm apply"
        Width="560" MinWidth="520" MaxWidth="820" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        CanResize="True"
        Background="{DynamicResource Surface0}"
        FontFamily="{StaticResource UiFont}">

  <Window.Resources>
    <conv:StageToBrushConverter x:Key="StageBrush" />
    <conv:StageToTextConverter  x:Key="StageText" />
    <conv:DangerAccentBrushConverter x:Key="AccentBrush" />
    <conv:OperationToBrushConverter x:Key="OpBrush" />
  </Window.Resources>

  <Border Padding="0" Background="{DynamicResource AppBackground}">
    <StackPanel Margin="28,26,28,24" Spacing="14">

      <StackPanel Orientation="Horizontal" Spacing="14" VerticalAlignment="Center">
        <Grid Width="44" Height="44">
          <Border CornerRadius="12"
                  Background="{DynamicResource Surface1}"
                  BorderBrush="{Binding UseDangerAccent, Converter={StaticResource AccentBrush}}"
                  BorderThickness="1" />
          <Path Data="{DynamicResource IcoApply}" Width="22" Height="22" Stretch="Uniform"
                Fill="{Binding UseDangerAccent, Converter={StaticResource AccentBrush}}"
                HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Grid>
        <StackPanel Spacing="2">
          <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
            <TextBlock Text="{Binding Headline}" Classes="eyebrow"
                       Foreground="{Binding UseDangerAccent, Converter={StaticResource AccentBrush}}" Margin="0" />
            <Border Classes="stage"
                    Background="{Binding Stage, Converter={StaticResource StageBrush}, ConverterParameter=soft}"
                    BorderBrush="{Binding Stage, Converter={StaticResource StageBrush}}">
              <TextBlock Text="{Binding Stage, Converter={StaticResource StageText}}"
                         Foreground="{Binding Stage, Converter={StaticResource StageBrush}}" />
            </Border>
          </StackPanel>
          <TextBlock Text="Apply changes" FontSize="20" FontWeight="Bold" />
        </StackPanel>
      </StackPanel>

      <Border Classes="pill err" IsVisible="{Binding IsProtected}" HorizontalAlignment="Left">
        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
          <Path Data="{DynamicResource IcoWarn}" Width="11" Height="11" Stretch="Uniform"
                Stroke="{DynamicResource Danger}" StrokeThickness="1.7" Fill="Transparent" />
          <TextBlock Text="PROTECTED ENVIRONMENT" Foreground="{DynamicResource Danger}" />
        </StackPanel>
      </Border>

      <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource TextSec}" FontSize="13" LineHeight="20">
        <Run Text="You are about to apply " />
        <Run Text="{Binding ChangeCount, Mode=OneTime}" FontWeight="Bold" Foreground="{DynamicResource TextPri}" />
        <Run Text=" change(s) to the connected environment. This cannot be undone automatically — a backup snapshot will be captured first." />
      </TextBlock>

      <!-- Drift: the live env changed since the snapshot was captured, so this diff may be incomplete.
           Amber (not red) — it's a "look before you leap", not a hard stop; the user may have caused it. -->
      <Border IsVisible="{Binding HasDrift}"
              CornerRadius="10" Padding="14,12" Background="{DynamicResource Surface1}"
              BorderBrush="{DynamicResource Warn}" BorderThickness="1.5">
        <StackPanel Spacing="6">
          <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
            <Path Data="{DynamicResource IcoWarn}" Width="14" Height="14" Stretch="Uniform"
                  Stroke="{DynamicResource Warn}" StrokeThickness="1.7" Fill="Transparent" />
            <TextBlock Text="SNAPSHOT MAY BE STALE" Classes="eyebrow"
                       Foreground="{DynamicResource Warn}" Margin="0" />
          </StackPanel>
          <TextBlock Text="{Binding DriftWarning}" FontSize="12.5"
                     Foreground="{DynamicResource TextSec}" TextWrapping="Wrap" />
          <TextBlock Text="Cancel and re-run Compare to be certain your diff reflects the current environment."
                     FontSize="12" Foreground="{DynamicResource TextSec}" TextWrapping="Wrap" />
        </StackPanel>
      </Border>

      <!-- Blast radius: how much LIVE data the destructive changes touch. Only shown when an apply
           would alter populated entity types — the difference between a safe edit and a data-loss event. -->
      <Border IsVisible="{Binding HasDataAtRisk}"
              CornerRadius="10" Padding="14,12" Background="{DynamicResource Surface1}"
              BorderBrush="{DynamicResource Danger}" BorderThickness="1.5">
        <StackPanel Spacing="8">
          <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
            <Path Data="{DynamicResource IcoWarn}" Width="14" Height="14" Stretch="Uniform"
                  Stroke="{DynamicResource Danger}" StrokeThickness="1.7" Fill="Transparent" />
            <TextBlock Text="LIVE DATA AT RISK" Classes="eyebrow"
                       Foreground="{DynamicResource Danger}" Margin="0" />
          </StackPanel>
          <TextBlock Text="{Binding DataAtRiskHeadline}" FontWeight="SemiBold" FontSize="13"
                     Foreground="{DynamicResource TextPri}" TextWrapping="Wrap" />
          <ItemsControl ItemsSource="{Binding DataAtRisk}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:ApplyRiskItem">
                <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,1">
                  <TextBlock Text="•" Foreground="{DynamicResource Danger}" />
                  <TextBlock Text="{Binding Description}" FontSize="12"
                             Foreground="{DynamicResource TextSec}" TextWrapping="Wrap" />
                </StackPanel>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </Border>

      <Border Classes="cardSubtle">
        <StackPanel Spacing="4">
          <TextBlock Text="TARGET" Classes="h3" />
          <TextBlock Text="{Binding EnvironmentUrl}" Classes="mono"
                     FontSize="13" Foreground="{DynamicResource TextPri}" TextWrapping="Wrap" />
        </StackPanel>
      </Border>

      <!-- Per-change review: lets the user see exactly what will be applied before committing. -->
      <Border Classes="cardSubtle" IsVisible="{Binding HasChanges}">
        <DockPanel>
          <TextBlock DockPanel.Dock="Top" Text="CHANGES TO APPLY" Classes="h3" Margin="0,0,0,6" />
          <ScrollViewer MaxHeight="220" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding Changes}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:ApplyReviewItem">
                  <Grid ColumnDefinitions="Auto,Auto,*" Margin="0,2">
                    <Border Grid.Column="0" Classes="pill" Background="Transparent"
                            BorderBrush="{Binding Operation, Converter={StaticResource OpBrush}}"
                            BorderThickness="1" MinWidth="58" Margin="0,0,8,0">
                      <TextBlock Text="{Binding Operation}" FontSize="11"
                                 HorizontalAlignment="Center"
                                 Foreground="{Binding Operation, Converter={StaticResource OpBrush}}" />
                    </Border>
                    <Path Grid.Column="1" Data="{DynamicResource IcoWarn}" Width="12" Height="12" Stretch="Uniform"
                          Stroke="{DynamicResource Danger}" StrokeThickness="1.6" Fill="Transparent"
                          VerticalAlignment="Center" Margin="0,0,6,0"
                          ToolTip.Tip="Destructive — deletes data or drops a field."
                          IsVisible="{Binding IsDangerous}" />
                    <TextBlock Grid.Column="2" Text="{Binding Description}" FontSize="12"
                               VerticalAlignment="Center" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"
                               Foreground="{DynamicResource TextSec}" />
                  </Grid>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </DockPanel>
      </Border>

      <Border Classes="cardSubtle"
              IsVisible="{Binding PolicySummary, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
        <StackPanel Spacing="4">
          <TextBlock Text="MERGE POLICY (in effect)" Classes="h3" />
          <TextBlock Text="{Binding PolicySummary}" Classes="mono" FontSize="12"
                     Foreground="{DynamicResource TextSec}" TextWrapping="Wrap" />
        </StackPanel>
      </Border>

      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,8,0,0">
        <Button Content="Cancel" Command="{Binding CancelCommand}" IsCancel="True" />
        <Button Content="Apply"  Command="{Binding ConfirmCommand}" Classes="primary" IsDefault="True" />
      </StackPanel>
    </StackPanel>
  </Border>
</Window>
