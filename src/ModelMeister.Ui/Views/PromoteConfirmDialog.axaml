<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ModelMeister.Ui.ViewModels"
        xmlns:conv="using:ModelMeister.Ui.Converters"
        x:Class="ModelMeister.Ui.Views.PromoteConfirmDialog"
        x:DataType="vm:PromoteConfirmViewModel"
        Title="Promote"
        Width="540" MinWidth="500" MaxWidth="780" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        CanResize="True"
        Background="{DynamicResource Surface0}"
        FontFamily="{StaticResource UiFont}">

  <Window.Resources>
    <conv:StageToBrushConverter x:Key="StageBrush" />
    <conv:StageToTextConverter  x:Key="StageText" />
  </Window.Resources>

  <Border Padding="0" Background="{DynamicResource AppBackground}">
    <StackPanel Margin="28,26,28,24" Spacing="14">

      <StackPanel Spacing="2">
        <TextBlock Text="PROMOTE" Classes="eyebrow" />
        <TextBlock Text="{Binding Headline}" FontSize="20" FontWeight="Bold" />
      </StackPanel>

      <Border Classes="pill err" IsVisible="{Binding IsProtected}" HorizontalAlignment="Left">
        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
          <Path Data="{DynamicResource IcoWarn}" Width="11" Height="11" Stretch="Uniform"
                Stroke="{DynamicResource Danger}" StrokeThickness="1.7" Fill="Transparent" />
          <TextBlock Text="PROTECTED TARGET" Foreground="{DynamicResource Danger}" />
        </StackPanel>
      </Border>

      <TextBlock Text="{Binding Detail}" TextWrapping="Wrap"
                 Foreground="{DynamicResource TextSec}" FontSize="13" LineHeight="20" />

      <Border Classes="cardSubtle">
        <StackPanel Spacing="6" Margin="10,8">
          <Grid ColumnDefinitions="60,Auto,*">
            <TextBlock Grid.Column="0" Text="From" Classes="dim" VerticalAlignment="Center" />
            <Border Grid.Column="1" Classes="stage" Margin="0,0,8,0" VerticalAlignment="Center"
                    IsVisible="{Binding SourceStage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                    Background="{Binding SourceStage, Converter={StaticResource StageBrush}, ConverterParameter=soft}"
                    BorderBrush="{Binding SourceStage, Converter={StaticResource StageBrush}}">
              <TextBlock Text="{Binding SourceStage, Converter={StaticResource StageText}}"
                         Foreground="{Binding SourceStage, Converter={StaticResource StageBrush}}" />
            </Border>
            <TextBlock Grid.Column="2" Text="{Binding SourceEnv}" Classes="mono" VerticalAlignment="Center" />
          </Grid>
          <Grid ColumnDefinitions="60,Auto,*">
            <TextBlock Grid.Column="0" Text="To" Classes="dim" VerticalAlignment="Center" />
            <Border Grid.Column="1" Classes="stage" Margin="0,0,8,0" VerticalAlignment="Center"
                    IsVisible="{Binding TargetStage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                    Background="{Binding TargetStage, Converter={StaticResource StageBrush}, ConverterParameter=soft}"
                    BorderBrush="{Binding TargetStage, Converter={StaticResource StageBrush}}">
              <TextBlock Text="{Binding TargetStage, Converter={StaticResource StageText}}"
                         Foreground="{Binding TargetStage, Converter={StaticResource StageBrush}}" />
            </Border>
            <TextBlock Grid.Column="2" Text="{Binding TargetEnv}" Classes="mono" VerticalAlignment="Center" />
          </Grid>
        </StackPanel>
      </Border>

      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,4,0,0">
        <Button Content="Abort"    Command="{Binding AbortCommand}"    IsCancel="True" />
        <Button Content="Continue" Command="{Binding ContinueCommand}" Classes="primary" IsDefault="True" />
      </StackPanel>
    </StackPanel>
  </Border>
</Window>
