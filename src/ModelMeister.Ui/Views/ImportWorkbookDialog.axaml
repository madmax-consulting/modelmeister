<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ModelMeister.Ui.ViewModels"
        x:Class="ModelMeister.Ui.Views.ImportWorkbookDialog"
        x:DataType="vm:ImportWorkbookViewModel"
        Title="Import from workbook"
        Width="560" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="{DynamicResource Surface0}"
        FontFamily="{StaticResource UiFont}">

  <Border Padding="0" Background="{DynamicResource AppBackground}">
    <StackPanel Margin="28,26,28,24" Spacing="14">

      <StackPanel Orientation="Horizontal" Spacing="14" VerticalAlignment="Center">
        <Grid Width="44" Height="44">
          <Border CornerRadius="12"
                  Background="{DynamicResource AccentGlowFill}"
                  BorderBrush="{DynamicResource AccentDeep}"
                  BorderThickness="1" />
          <Path Data="{DynamicResource IcoCopy}" Width="22" Height="22" Stretch="Uniform"
                Stroke="{DynamicResource Accent}" StrokeThickness="1.5"
                StrokeJoin="Round" StrokeLineCap="Round" Fill="Transparent"
                HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Grid>
        <StackPanel Spacing="2">
          <TextBlock Text="IMPORT FROM EXCEL" Classes="eyebrow" />
          <TextBlock Text="{Binding Title}" FontSize="20" FontWeight="Bold" />
        </StackPanel>
      </StackPanel>

      <TextBlock Text="{Binding Subtitle}" TextWrapping="Wrap"
                 Foreground="{DynamicResource TextSec}" FontSize="13" LineHeight="20" />

      <StackPanel Spacing="6">
        <TextBlock Text="WORKBOOK" Classes="label" />
        <Grid ColumnDefinitions="*,Auto">
          <TextBox Grid.Column="0" Text="{Binding WorkbookPath, Mode=TwoWay}"
                   Classes="mono" Watermark="path\to\workbook.xlsx" />
          <Button Grid.Column="1" Content="Pick…" Command="{Binding PickCommand}"
                  Classes="ghost" Margin="8,0,0,0" />
        </Grid>
      </StackPanel>

      <CheckBox Content="Dry run (preview only — don't write)"
                IsChecked="{Binding DryRun, Mode=TwoWay}"
                IsVisible="{Binding SupportsDryRun}" />

      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,8,0,0">
        <Button Content="Cancel" Command="{Binding CancelCommand}" IsCancel="True" />
        <Button Content="Import" Command="{Binding ConfirmCommand}" Classes="primary" IsDefault="True" />
      </StackPanel>
    </StackPanel>
  </Border>
</Window>
