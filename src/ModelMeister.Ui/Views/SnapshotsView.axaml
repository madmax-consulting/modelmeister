<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ModelMeister.Ui.ViewModels"
             xmlns:svc="using:ModelMeister.Ui.Services"
             xmlns:c="using:ModelMeister.Ui.Controls"
             x:Class="ModelMeister.Ui.Views.SnapshotsView"
             x:DataType="vm:SnapshotsViewModel">

  <UserControl.KeyBindings>
    <!-- Delete key targets the currently-selected backup row. -->
    <KeyBinding Gesture="Delete"
                Command="{Binding DeleteCommand}"
                CommandParameter="{Binding #BackupsGrid.SelectedItem}" />
  </UserControl.KeyBindings>

  <!-- Single-row PageShell header: Eyebrow + Subtitle on the left; Capture + standard PageActions
       (Refresh) on the right. Scope is filtered in-place via the column header below — no second
       toolbar row. -->
  <c:PageShell Eyebrow="BACKUP LIBRARY"
               Subtitle="Every scoped or full snapshot the app has captured, in one place"
               Status="{Binding Summary}"
               IsBusy="{Binding Busy}">
    <c:PageShell.Actions>
      <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
        <Button Classes="primary"
                Content="Capture full snapshot"
                Command="{Binding CaptureFullCommand}" />
        <c:PageActions DataContext="{Binding}" />
      </StackPanel>
    </c:PageShell.Actions>

    <Border Classes="card flush" Padding="0">
      <Grid>
        <!-- Empty state: shown when no backups have been captured yet. Mirrors UsersView's pattern
             (centered text + cta) so an empty library no longer renders as a blank dark surface. -->
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                    Spacing="6" Margin="0,40"
                    IsVisible="{Binding Rows.Count, Converter={x:Static svc:Eq.IsZero}}">
          <TextBlock Text="No backups captured yet"
                     FontWeight="SemiBold" FontSize="14"
                     HorizontalAlignment="Center" />
          <TextBlock Text="Use Capture full snapshot to take one."
                     Classes="subtle"
                     HorizontalAlignment="Center" />
          <Button Content="Capture full snapshot"
                  Command="{Binding CaptureFullCommand}"
                  Classes="primary"
                  HorizontalAlignment="Center"
                  Margin="0,4,0,0" />
        </StackPanel>

        <DataGrid Name="BackupsGrid"
                  ItemsSource="{Binding Rows}" IsReadOnly="True"
                  AutoGenerateColumns="False"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  ColumnHeaderHeight="62"
                  Margin="0" BorderThickness="0" CornerRadius="0"
                  DoubleTapped="OnRowDoubleTapped">
          <DataGrid.ContextMenu>
            <ContextMenu>
              <MenuItem Header="Open"
                        Command="{Binding OpenInExplorerCommand}"
                        CommandParameter="{Binding #BackupsGrid.SelectedItem}" />
              <MenuItem Header="Open folder"
                        Command="{Binding OpenInExplorerCommand}"
                        CommandParameter="{Binding #BackupsGrid.SelectedItem}" />
              <Separator />
              <MenuItem Header="Copy path"
                        Command="{Binding CopyPathCommand}"
                        CommandParameter="{Binding #BackupsGrid.SelectedItem}" />
              <Separator />
              <MenuItem Header="Delete"
                        Command="{Binding DeleteCommand}"
                        CommandParameter="{Binding #BackupsGrid.SelectedItem}" />
            </ContextMenu>
          </DataGrid.ContextMenu>
          <DataGrid.Columns>
            <!-- Scope-as-column-filter (preserves commit 51ec2fc). MinWidth lets columns size to
                 content while keeping a sensible floor; only File gets Width="*" so it absorbs
                 the slack rather than every column fighting for it. -->
            <DataGridTextColumn Binding="{Binding Scope}" MinWidth="110">
              <DataGridTextColumn.Header><c:FilterableHeader Title="Scope" Path="Scope" /></DataGridTextColumn.Header>
            </DataGridTextColumn>
            <DataGridTextColumn Binding="{Binding EnvName}" MinWidth="180">
              <DataGridTextColumn.Header><c:FilterableHeader Title="Env" Path="EnvName" /></DataGridTextColumn.Header>
            </DataGridTextColumn>
            <DataGridTextColumn Binding="{Binding CapturedAt}" MinWidth="150">
              <DataGridTextColumn.Header><c:FilterableHeader Title="Captured" Path="CapturedAt" /></DataGridTextColumn.Header>
            </DataGridTextColumn>
            <DataGridTextColumn Binding="{Binding KindLabel}" MinWidth="80">
              <DataGridTextColumn.Header><c:FilterableHeader Title="Kind" Path="KindLabel" /></DataGridTextColumn.Header>
            </DataGridTextColumn>
            <DataGridTextColumn Binding="{Binding Size}" MinWidth="80">
              <DataGridTextColumn.Header><c:FilterableHeader Title="Size" Path="Size" /></DataGridTextColumn.Header>
            </DataGridTextColumn>
            <DataGridTextColumn Binding="{Binding FileName}" Width="*" MinWidth="200">
              <DataGridTextColumn.Header><c:FilterableHeader Title="File" Path="FileName" /></DataGridTextColumn.Header>
            </DataGridTextColumn>
            <DataGridTemplateColumn Header="" Width="180">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate x:DataType="vm:BackupRow">
                  <StackPanel Orientation="Horizontal" Spacing="3" Margin="4,0">
                    <Button Classes="ghost" Padding="6,2" MinHeight="22"
                            Content="Open"
                            Command="{Binding $parent[DataGrid].((vm:SnapshotsViewModel)DataContext).OpenInExplorerCommand}"
                            CommandParameter="{Binding}" />
                    <Button Classes="ghost danger" Padding="6,2" MinHeight="22"
                            Content="Delete"
                            Command="{Binding $parent[DataGrid].((vm:SnapshotsViewModel)DataContext).DeleteCommand}"
                            CommandParameter="{Binding}" />
                  </StackPanel>
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>
          </DataGrid.Columns>
        </DataGrid>
      </Grid>
    </Border>

  </c:PageShell>
</UserControl>
