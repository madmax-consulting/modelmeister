<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:ModelMeister.Ui.ViewModels"
        xmlns:svc="using:ModelMeister.Ui.Services"
        xmlns:conv="using:ModelMeister.Ui.Converters"
        xmlns:m="using:ModelMeister.Ui.Models"
        mc:Ignorable="d"
        x:Class="ModelMeister.Ui.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="ModelMeister"
        Width="1320" Height="860"
        MinWidth="1024" MinHeight="660"
        FontFamily="{StaticResource UiFont}"
        Background="{DynamicResource AppBackground}"
        TransparencyLevelHint="Mica,AcrylicBlur,Blur,None">

  <Window.Resources>
    <conv:ConnectionStateToBrushConverter x:Key="ConnState" />
    <conv:ConnectionStateToGlyphConverter x:Key="ConnGlyph" />
    <conv:ResourceKeyToGeometryConverter  x:Key="IconLookup" />
    <conv:StageToBrushConverter x:Key="StageBrush" />
    <conv:StageToTextConverter  x:Key="StageText" />
    <conv:LogLevelToBrushConverter x:Key="LogLevelBrush" />
  </Window.Resources>

  <!-- Global keyboard shortcuts. Page-scoped bindings (Delete/Ctrl+N/Ctrl+E/etc) live on each
       UserControl so they only fire when that page is active. -->
  <Window.KeyBindings>
    <KeyBinding Gesture="F5"           Command="{Binding RefreshCurrentPageCommand}" />
    <KeyBinding Gesture="Ctrl+Shift+E" Command="{Binding GoToEnvironmentsCommand}" />
    <KeyBinding Gesture="Ctrl+Shift+M" Command="{Binding GoToModelHubCommand}" />
  </Window.KeyBindings>

  <Grid RowDefinitions="40,*,Auto">

    <!-- =============================================================
         Row 0: TitleBar
         brand · (separator) · hub title · sub-page tabs · source chip · theme toggle
         ============================================================= -->
    <Border Grid.Row="0"
            Background="{DynamicResource Surface1}"
            BorderBrush="{DynamicResource Border}"
            BorderThickness="0,0,0,1"
            Padding="6,0">
      <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,*,Auto,Auto" VerticalAlignment="Center">

        <!-- Rail toggle -->
        <Button Grid.Column="0" Classes="ghost icon"
                Command="{Binding ToggleRailCommand}"
                ToolTip.Tip="Toggle sidebar">
          <Path Data="{DynamicResource IcoExpandAll}" Width="14" Height="14" Stretch="Uniform"
                Stroke="{DynamicResource TextSec}" StrokeThickness="1.6"
                StrokeJoin="Round" StrokeLineCap="Round" Fill="Transparent" />
        </Button>

        <!-- Brand -->
        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" Margin="6,0,8,0" VerticalAlignment="Center">
          <Grid Width="22" Height="22">
            <Border CornerRadius="6" Background="{DynamicResource AccentGlowFill}" />
            <Path Data="{DynamicResource IcoLogo}"
                  Stroke="{DynamicResource Accent}" StrokeThickness="1.5"
                  StrokeJoin="Round" StrokeLineCap="Round" Fill="Transparent"
                  Width="14" Height="14" Stretch="Uniform"
                  HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Grid>
          <TextBlock Text="ModelMeister" FontSize="13" FontWeight="Bold" LetterSpacing="-0.2"
                     VerticalAlignment="Center" />
        </StackPanel>

        <!-- Divider -->
        <Border Grid.Column="2" Width="1" Margin="4,8" Background="{DynamicResource Border}" />

        <!-- Hub title -->
        <TextBlock Grid.Column="3"
                   Text="{Binding SelectedHub.Title}"
                   FontSize="13" FontWeight="SemiBold"
                   Margin="8,0,12,0" VerticalAlignment="Center" />

        <!-- Sub-page tabs (only when current hub has sub-pages) -->
        <ListBox Grid.Column="4"
                 Classes="hubtabs"
                 ItemsSource="{Binding SubPages}"
                 SelectedItem="{Binding SelectedSubPage, Mode=TwoWay}"
                 VerticalAlignment="Center"
                 HorizontalAlignment="Left"
                 Background="Transparent"
                 BorderThickness="0">
          <ListBox.ItemsPanel>
            <ItemsPanelTemplate>
              <StackPanel Orientation="Horizontal" Spacing="0" />
            </ItemsPanelTemplate>
          </ListBox.ItemsPanel>
          <ListBox.ItemTemplate>
            <DataTemplate x:DataType="m:SubPageDescriptor">
              <TextBlock Text="{Binding Title}" Padding="10,5" FontSize="12" />
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>

        <!-- Connection chip: clickable flyout exposes Disconnect / Manage envs on every page. -->
        <Button Grid.Column="5" Classes="ghost"
                Padding="8,3" Margin="0,4,8,4"
                VerticalAlignment="Center"
                ToolTip.Tip="Click for connection options">
          <Button.Content>
            <Panel>
              <!-- When connected: env name + stage badge -->
              <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center"
                          IsVisible="{Binding IsConnected}">
                <Ellipse Width="7" Height="7"
                         Fill="{Binding ConnectionStatus, Converter={StaticResource ConnState}}" />
                <TextBlock Text="{Binding ConnectedEnv.Name}" FontSize="11" FontWeight="SemiBold" />
                <Border Classes="stage"
                        Background="{Binding ConnectedStage, Converter={StaticResource StageBrush}, ConverterParameter=soft}"
                        BorderBrush="{Binding ConnectedStage, Converter={StaticResource StageBrush}}">
                  <TextBlock Text="{Binding ConnectedStage, Converter={StaticResource StageText}}"
                             Foreground="{Binding ConnectedStage, Converter={StaticResource StageBrush}}" />
                </Border>
              </StackPanel>
              <!-- When not connected: dim "Not connected" -->
              <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center"
                          IsVisible="{Binding !IsConnected}">
                <Ellipse Width="7" Height="7" Fill="{DynamicResource TextDim}" />
                <TextBlock Text="Not connected" FontSize="11" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextSec}" />
              </StackPanel>
            </Panel>
          </Button.Content>
          <Button.Flyout>
            <Flyout Placement="Bottom">
              <Border Padding="14,12" MinWidth="280">
                <StackPanel Spacing="10">
                  <!-- Connected state -->
                  <StackPanel Spacing="6" IsVisible="{Binding IsConnected}">
                    <TextBlock Text="CONNECTED TO" Classes="eyebrow" />
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                      <TextBlock Text="{Binding ConnectedEnv.Name}" FontWeight="SemiBold" FontSize="14" />
                      <Border Classes="stage"
                              Background="{Binding ConnectedStage, Converter={StaticResource StageBrush}, ConverterParameter=soft}"
                              BorderBrush="{Binding ConnectedStage, Converter={StaticResource StageBrush}}">
                        <TextBlock Text="{Binding ConnectedStage, Converter={StaticResource StageText}}"
                                   Foreground="{Binding ConnectedStage, Converter={StaticResource StageBrush}}" />
                      </Border>
                    </StackPanel>
                    <TextBlock Text="{Binding ConnectedEnv.Url}" Classes="mono dim" TextWrapping="Wrap" />
                  </StackPanel>

                  <!-- Disconnected state -->
                  <StackPanel Spacing="6" IsVisible="{Binding !IsConnected}">
                    <TextBlock Text="NOT CONNECTED" Classes="eyebrow" />
                    <TextBlock Text="Pick an environment from the Environments hub to connect."
                               Classes="subtle" TextWrapping="Wrap" />
                  </StackPanel>

                  <Border Classes="divider" />

                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="Disconnect" Classes="danger"
                            Command="{Binding DisconnectCommand}"
                            IsVisible="{Binding IsConnected}" />
                    <Button Content="Manage environments" Classes="ghost"
                            Command="{Binding GoToEnvironmentsCommand}" />
                  </StackPanel>
                </StackPanel>
              </Border>
            </Flyout>
          </Button.Flyout>
        </Button>

        <!-- Theme toggle: shows the icon of the theme you'll switch TO. -->
        <Button Grid.Column="6" Classes="ghost icon"
                Command="{Binding ToggleThemeCommand}"
                VerticalAlignment="Center"
                ToolTip.Tip="Switch theme">
          <Panel>
            <Path Data="{DynamicResource IcoSun}" Width="14" Height="14" Stretch="Uniform"
                  Stroke="{DynamicResource TextSec}" StrokeThickness="1.6"
                  StrokeJoin="Round" StrokeLineCap="Round" Fill="Transparent"
                  IsVisible="{Binding IsDarkTheme}" />
            <Path Data="{DynamicResource IcoMoon}" Width="14" Height="14" Stretch="Uniform"
                  Stroke="{DynamicResource TextSec}" StrokeThickness="1.6"
                  StrokeJoin="Round" StrokeLineCap="Round" Fill="Transparent"
                  IsVisible="{Binding !IsDarkTheme}" />
          </Panel>
        </Button>
      </Grid>
    </Border>

    <!-- =============================================================
         Row 1: SplitView with collapsible nav rail + content
         ============================================================= -->
    <SplitView Grid.Row="1"
               DisplayMode="CompactInline"
               OpenPaneLength="220"
               CompactPaneLength="56"
               IsPaneOpen="{Binding IsRailExpanded}"
               PaneBackground="{DynamicResource Surface1}">

      <SplitView.Pane>
        <DockPanel LastChildFill="True">

          <!-- Connection status footer (compact form when rail collapsed) -->
          <Border DockPanel.Dock="Bottom"
                  BorderBrush="{DynamicResource BorderFaint}"
                  BorderThickness="0,1,0,0"
                  Padding="12,10">
            <StackPanel Spacing="6">
              <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Ellipse Width="8" Height="8"
                         Fill="{Binding ConnectionStatus, Converter={StaticResource ConnState}}" />
                <TextBlock Text="{Binding ConnectionStatus}" FontSize="11" FontWeight="SemiBold"
                           IsVisible="{Binding IsRailExpanded}" />
              </StackPanel>
              <TextBlock Text="{Binding ConnectionDetail}" FontSize="11"
                         Foreground="{DynamicResource TextDim}" TextWrapping="Wrap"
                         IsVisible="{Binding IsRailExpanded}" />
            </StackPanel>
          </Border>

          <!-- Nav (grouped: HOME / MANAGE / SYSTEM). Three ListBoxes share SelectedHub; the
               non-owning ones drop their selection when SelectedHub moves to another group. -->
          <ScrollViewer HorizontalScrollBarVisibility="Disabled">
            <StackPanel>

              <TextBlock Text="HOME" Classes="h3" Margin="20,14,20,4"
                         IsVisible="{Binding ShowHomeHeader}" />
              <ListBox Classes="nav"
                       IsVisible="{Binding HasHomeHubs}"
                       ItemsSource="{Binding HomeHubs}"
                       SelectedItem="{Binding SelectedHub, Mode=OneWay}"
                       SelectionChanged="OnHubSelectionChanged">
                <ListBox.ItemTemplate>
                  <DataTemplate x:DataType="m:HubDescriptor">
                    <Grid ColumnDefinitions="3,Auto,*" Height="40">
                      <Border x:Name="NavInd" Grid.Column="0" Width="3" CornerRadius="0,2,2,0" Background="Transparent" />
                      <Path Grid.Column="1" Margin="14,0,12,0" VerticalAlignment="Center"
                            Data="{Binding IconKey, Converter={StaticResource IconLookup}}"
                            Stroke="{DynamicResource TextSec}" StrokeThickness="1.5"
                            StrokeJoin="Round" StrokeLineCap="Round" Fill="Transparent"
                            Width="18" Height="18" Stretch="Uniform"
                            ToolTip.Tip="{Binding Title}" />
                      <TextBlock Grid.Column="2" Text="{Binding Title}"
                                 VerticalAlignment="Center"
                                 FontSize="13" FontWeight="Medium"
                                 Foreground="{DynamicResource TextSec}"
                                 IsVisible="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).IsRailExpanded}" />
                    </Grid>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>

              <TextBlock Text="MANAGE" Classes="h3" Margin="20,14,20,4"
                         IsVisible="{Binding IsRailExpanded}" />
              <ListBox Classes="nav"
                       ItemsSource="{Binding ManageHubs}"
                       SelectedItem="{Binding SelectedHub, Mode=OneWay}"
                       SelectionChanged="OnHubSelectionChanged">
                <ListBox.ItemTemplate>
                  <DataTemplate x:DataType="m:HubDescriptor">
                    <Grid ColumnDefinitions="3,Auto,*" Height="40">
                      <Border x:Name="NavInd" Grid.Column="0" Width="3" CornerRadius="0,2,2,0" Background="Transparent" />
                      <Path Grid.Column="1" Margin="14,0,12,0" VerticalAlignment="Center"
                            Data="{Binding IconKey, Converter={StaticResource IconLookup}}"
                            Stroke="{DynamicResource TextSec}" StrokeThickness="1.5"
                            StrokeJoin="Round" StrokeLineCap="Round" Fill="Transparent"
                            Width="18" Height="18" Stretch="Uniform"
                            ToolTip.Tip="{Binding Title}" />
                      <TextBlock Grid.Column="2" Text="{Binding Title}"
                                 VerticalAlignment="Center"
                                 FontSize="13" FontWeight="Medium"
                                 Foreground="{DynamicResource TextSec}"
                                 IsVisible="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).IsRailExpanded}" />
                    </Grid>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>

              <TextBlock Text="SYSTEM" Classes="h3" Margin="20,14,20,4"
                         IsVisible="{Binding IsRailExpanded}" />
              <ListBox Classes="nav"
                       ItemsSource="{Binding SystemHubs}"
                       SelectedItem="{Binding SelectedHub, Mode=OneWay}"
                       SelectionChanged="OnHubSelectionChanged">
                <ListBox.ItemTemplate>
                  <DataTemplate x:DataType="m:HubDescriptor">
                    <Grid ColumnDefinitions="3,Auto,*" Height="40">
                      <Border x:Name="NavInd" Grid.Column="0" Width="3" CornerRadius="0,2,2,0" Background="Transparent" />
                      <Path Grid.Column="1" Margin="14,0,12,0" VerticalAlignment="Center"
                            Data="{Binding IconKey, Converter={StaticResource IconLookup}}"
                            Stroke="{DynamicResource TextSec}" StrokeThickness="1.5"
                            StrokeJoin="Round" StrokeLineCap="Round" Fill="Transparent"
                            Width="18" Height="18" Stretch="Uniform"
                            ToolTip.Tip="{Binding Title}" />
                      <TextBlock Grid.Column="2" Text="{Binding Title}"
                                 VerticalAlignment="Center"
                                 FontSize="13" FontWeight="Medium"
                                 Foreground="{DynamicResource TextSec}"
                                 IsVisible="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).IsRailExpanded}" />
                    </Grid>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>

            </StackPanel>
          </ScrollViewer>

        </DockPanel>
      </SplitView.Pane>

      <SplitView.Content>
        <Grid RowDefinitions="Auto,*">
          <!-- WorkflowStrip: shown only on Model → Manage. Chips jump between reachable steps;
               the Next button on the right advances in strip order and is gated by CanGoNext. -->
          <Border Grid.Row="0"
                  IsVisible="{Binding IsModelManageActive}"
                  Background="{DynamicResource Surface1}"
                  BorderBrush="{DynamicResource BorderFaint}"
                  BorderThickness="0,0,0,1"
                  Padding="14,6">
            <Grid ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Center">
              <TextBlock Grid.Column="0" Text="WORKFLOW" Classes="h3"
                         Margin="0,0,10,0" VerticalAlignment="Center" />

              <ItemsControl Grid.Column="1" ItemsSource="{Binding WorkflowSteps}"
                            HorizontalAlignment="Left" VerticalAlignment="Center">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center" />
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="vm:WorkflowStepItem">
                    <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">

                      <Button Classes="step"
                              Classes.done="{Binding IsDone}"
                              Classes.current="{Binding IsCurrent}"
                              IsEnabled="{Binding IsClickable}"
                              Command="{Binding ActivateCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                          <Panel Width="12" Height="12">
                            <Ellipse Classes="stepGlyph" Width="12" Height="12"
                                     Stroke="{DynamicResource TextDim}" StrokeThickness="1.6" Fill="Transparent" />
                            <Path Classes="stepGlyph" Data="{DynamicResource IcoCheck}"
                                  Width="12" Height="12" Stretch="Uniform"
                                  Stroke="{DynamicResource Success}" StrokeThickness="2"
                                  StrokeJoin="Round" StrokeLineCap="Round" Fill="Transparent" />
                          </Panel>
                          <TextBlock Text="{Binding Title}" />
                        </StackPanel>
                      </Button>

                      <Path Data="{DynamicResource IcoChevRight}" Width="10" Height="10" Stretch="Uniform"
                            Stroke="{DynamicResource TextDim}" StrokeThickness="1.5" Fill="Transparent"
                            VerticalAlignment="Center" Margin="2,0"
                            IsVisible="{Binding HasSeparator}" />

                    </StackPanel>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>

              <Button Grid.Column="2" Classes="primary"
                      Command="{Binding GoNextCommand}"
                      IsEnabled="{Binding CanGoNext}"
                      IsVisible="{Binding ShowNext}"
                      VerticalAlignment="Center"
                      Margin="12,0,0,0"
                      ToolTip.Tip="Advance to the next workflow step">
                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                  <TextBlock Text="Next" />
                  <Path Data="{DynamicResource IcoArrowRight}" Width="11" Height="11" Stretch="Uniform"
                        Stroke="{DynamicResource AccentButtonForeground}" StrokeThickness="1.8"
                        StrokeJoin="Round" StrokeLineCap="Round" Fill="Transparent" />
                </StackPanel>
              </Button>
            </Grid>
          </Border>

          <Border Grid.Row="1" Padding="16,12,16,14"
                  BorderBrush="{DynamicResource Danger}"
                  BorderThickness="{Binding IsProdConnected, Converter={x:Static svc:BoolToThicknessConverter.PROD}}">
            <ContentControl Content="{Binding CurrentPage}" />
          </Border>

            <!-- Toast snackbar host (bottom-right) -->
            <ItemsControl Grid.Row="1"
                          ItemsSource="{Binding Log.Toasts}"
                          HorizontalAlignment="Right"
                          VerticalAlignment="Bottom"
                          Margin="0,0,24,24">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <StackPanel Spacing="10" />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="svc:ToastEntry">
                  <Border Classes="toast"
                          Classes.success="{Binding Level, ConverterParameter=Success, Converter={x:Static svc:Eq.Compare}}"
                          Classes.warn="{Binding Level, ConverterParameter=Warn, Converter={x:Static svc:Eq.Compare}}"
                          Classes.error="{Binding Level, ConverterParameter=Error, Converter={x:Static svc:Eq.Compare}}"
                          Classes.info="{Binding Level, ConverterParameter=Info, Converter={x:Static svc:Eq.Compare}}">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                      <Ellipse Grid.Column="0" Width="10" Height="10"
                               Fill="{Binding LevelText, Converter={StaticResource LogLevelBrush}}"
                               VerticalAlignment="Top" Margin="0,4,10,0" />
                      <StackPanel Grid.Column="1" Spacing="2">
                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextWrapping="Wrap" />
                        <TextBlock Text="{Binding Detail}" Classes="subtle" TextWrapping="Wrap"
                                   IsVisible="{Binding Detail, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                      </StackPanel>
                      <Button Grid.Column="2" Classes="ghost icon"
                              Margin="6,0,0,0" Padding="6"
                              Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).DismissToastCommand}"
                              CommandParameter="{Binding}">
                        <Path Data="{DynamicResource IcoX}" Width="11" Height="11" Stretch="Uniform"
                              Stroke="{DynamicResource TextSec}" StrokeThickness="1.7" Fill="Transparent" />
                      </Button>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>
      </SplitView.Content>
    </SplitView>

    <!-- =============================================================
         Row 2: Log drawer (collapsible bottom panel)
         ============================================================= -->
    <Border Grid.Row="2"
            Background="{DynamicResource Surface1}"
            BorderBrush="{DynamicResource Border}"
            BorderThickness="0,1,0,0">
      <DockPanel LastChildFill="True">

        <!-- Drawer header strip -->
        <Border DockPanel.Dock="Top" Padding="14,6" Background="{DynamicResource Surface0}"
                BorderBrush="{DynamicResource BorderFaint}" BorderThickness="0,0,0,1">
          <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto">
            <Button Grid.Column="0" Classes="ghost" Command="{Binding ToggleLogDrawerCommand}" Padding="6,2">
              <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Path Width="10" Height="10" Stretch="Uniform"
                      Stroke="{DynamicResource TextSec}" StrokeThickness="2"
                      StrokeJoin="Round" StrokeLineCap="Round" Fill="Transparent"
                      Data="{Binding LogDrawerExpanded, Converter={x:Static svc:Eq.ChevForExpanded}}" />
                <TextBlock Text="ACTIVITY LOG" Classes="h3" />
              </StackPanel>
            </Button>
            <Border Grid.Column="1" Classes="pill" Margin="8,0,0,0"
                    Background="{DynamicResource AccentSoft}"
                    BorderBrush="{DynamicResource Accent}" BorderThickness="1"
                    IsVisible="{Binding LogUnseenCount, Converter={x:Static svc:Eq.GtZero}}">
              <TextBlock Text="{Binding LogUnseenCount, StringFormat='{}{0} new'}"
                         Foreground="{DynamicResource AccentBright}" />
            </Border>
            <TextBlock Grid.Column="2" Text="" />
            <Button Grid.Column="3" Classes="ghost" Content="Clear" Command="{Binding ClearLogCommand}"
                    IsVisible="{Binding LogDrawerExpanded}" />
            <Button Grid.Column="4" Classes="ghost" Margin="4,0,0,0"
                    Command="{Binding ToggleLogDrawerCommand}"
                    IsVisible="{Binding LogDrawerExpanded}">
              <Path Data="{DynamicResource IcoX}" Width="11" Height="11" Stretch="Uniform"
                    Stroke="{DynamicResource TextSec}" StrokeThickness="1.7" Fill="Transparent" />
            </Button>
          </Grid>
        </Border>

        <!-- Drawer body -->
        <Border Height="200" IsVisible="{Binding LogDrawerExpanded}">
          <ScrollViewer HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding Log.Entries}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="svc:LogEntry">
                  <Border Classes="logEntry">
                    <Grid ColumnDefinitions="64,80,140,*">
                      <TextBlock Grid.Column="0" Text="{Binding Time}" Classes="mono"
                                 Foreground="{DynamicResource TextDim}" />
                      <Border Grid.Column="1" Classes="pill"
                              Background="Transparent"
                              BorderBrush="{Binding LevelText, Converter={StaticResource LogLevelBrush}}"
                              BorderThickness="1"
                              HorizontalAlignment="Left">
                        <TextBlock Text="{Binding LevelText}"
                                   Foreground="{Binding LevelText, Converter={StaticResource LogLevelBrush}}" />
                      </Border>
                      <TextBlock Grid.Column="2" Text="{Binding Source}"
                                 FontWeight="SemiBold" Foreground="{DynamicResource TextSec}"
                                 VerticalAlignment="Center" Margin="10,0,0,0" />
                      <TextBlock Grid.Column="3" Text="{Binding Message}" TextWrapping="Wrap"
                                 VerticalAlignment="Center" Margin="6,0,0,0" />
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </Border>
      </DockPanel>
    </Border>
  </Grid>
</Window>
