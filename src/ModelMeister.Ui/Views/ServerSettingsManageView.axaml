<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ModelMeister.Ui.ViewModels"
             xmlns:c="using:ModelMeister.Ui.Controls"
             x:Class="ModelMeister.Ui.Views.ServerSettingsManageView"
             x:DataType="vm:ServerSettingsManageViewModel">

  <UserControl.KeyBindings>
    <KeyBinding Gesture="Delete"
                Command="{Binding DeleteCommand}"
                CommandParameter="{Binding #SettingsGrid.SelectedItem}" />
  </UserControl.KeyBindings>

  <c:PageShell Eyebrow="SERVER SETTINGS"
               Subtitle="Key/value settings on the connected environment"
               Status="{Binding Status}"
               IsBusy="{Binding Busy}">
    <c:PageShell.Actions>
      <c:PageActions DataContext="{Binding}" />
    </c:PageShell.Actions>

    <Border Classes="card flush" Padding="0">
      <Grid RowDefinitions="Auto,Auto,*">

        <!-- Add-new strip -->
        <Grid Grid.Row="0" Margin="10,10,10,6" ColumnDefinitions="Auto,*,Auto,*,Auto">
          <TextBlock Grid.Column="0" Text="ADD" Classes="eyebrow" VerticalAlignment="Center" Margin="0,0,8,0" />
          <TextBox Grid.Column="1" Text="{Binding NewKey, Mode=TwoWay}" Watermark="key (e.g. inriver.SomeFlag)" Classes="mono" />
          <TextBlock Grid.Column="2" Text="=" Margin="8,0" Foreground="{DynamicResource TextDim}" VerticalAlignment="Center" />
          <TextBox Grid.Column="3" Text="{Binding NewValue, Mode=TwoWay}" Watermark="value" />
          <Button Grid.Column="4" Content="Create" Margin="8,0,0,0"
                  Command="{Binding AddCommand}" Classes="primary" IsEnabled="{Binding !Busy}" />
        </Grid>

        <!-- Filter strip -->
        <Grid Grid.Row="1" Margin="10,2,10,6" ColumnDefinitions="Auto,*">
          <TextBox Grid.Column="0" Text="{Binding FilterText, Mode=TwoWay}" Width="260"
                   Watermark="filter key or value" />
        </Grid>

        <!-- Grid -->
        <DataGrid Grid.Row="2"
                  Name="SettingsGrid"
                  ItemsSource="{Binding Rows}" IsReadOnly="False"
                  AutoGenerateColumns="False" SelectionMode="Single"
                  Margin="0" BorderThickness="1,1,1,0" CornerRadius="0">
          <DataGrid.ContextMenu>
            <ContextMenu>
              <MenuItem Header="Save change"
                        Command="{Binding SaveCommand}"
                        CommandParameter="{Binding #SettingsGrid.SelectedItem}" />
              <MenuItem Header="Revert change"
                        Command="{Binding RevertRowCommand}"
                        CommandParameter="{Binding #SettingsGrid.SelectedItem}" />
              <Separator />
              <MenuItem Header="Copy key"
                        Command="{Binding CopyKeyCommand}"
                        CommandParameter="{Binding #SettingsGrid.SelectedItem}" />
              <MenuItem Header="Copy value"
                        Command="{Binding CopyValueCommand}"
                        CommandParameter="{Binding #SettingsGrid.SelectedItem}" />
              <Separator />
              <MenuItem Header="Delete"
                        Command="{Binding DeleteCommand}"
                        CommandParameter="{Binding #SettingsGrid.SelectedItem}" />
            </ContextMenu>
          </DataGrid.ContextMenu>
          <DataGrid.Columns>
            <DataGridTextColumn Header="Key" Binding="{Binding Key}" Width="320" IsReadOnly="True" />
            <DataGridTextColumn Header="Value" Binding="{Binding Value, Mode=TwoWay}" Width="*" />
            <DataGridTemplateColumn Header="" Width="180" IsReadOnly="True">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate x:DataType="vm:ServerSettingEditRow">
                  <StackPanel Orientation="Horizontal" Spacing="4" Margin="4,0">
                    <Button Content="Save" Classes="primary"
                            IsVisible="{Binding IsDirty}"
                            Command="{Binding $parent[DataGrid].((vm:ServerSettingsManageViewModel)DataContext).SaveCommand}"
                            CommandParameter="{Binding}" />
                    <Button Content="Revert" Classes="ghost"
                            IsVisible="{Binding IsDirty}"
                            Command="{Binding $parent[DataGrid].((vm:ServerSettingsManageViewModel)DataContext).RevertRowCommand}"
                            CommandParameter="{Binding}" />
                    <Button Content="Delete" Classes="ghost"
                            Command="{Binding $parent[DataGrid].((vm:ServerSettingsManageViewModel)DataContext).DeleteCommand}"
                            CommandParameter="{Binding}" />
                  </StackPanel>
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>
          </DataGrid.Columns>
        </DataGrid>
      </Grid>
    </Border>

  </c:PageShell>
</UserControl>
