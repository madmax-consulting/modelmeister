<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ModelMeister.Ui.ViewModels"
             xmlns:c="using:ModelMeister.Ui.Controls"
             x:Class="ModelMeister.Ui.Views.CvlWorkbenchView"
             x:DataType="vm:CvlWorkbenchViewModel">

  <c:PageShell Eyebrow="CVL WORKBENCH"
               Subtitle="Controlled Value Lists on the connected environment"
               Status="{Binding Status}"
               IsBusy="{Binding Busy}">
    <c:PageShell.Actions>
      <c:PageActions DataContext="{Binding}" />
    </c:PageShell.Actions>

    <Border Classes="card flush" Padding="0">
      <DataGrid Name="CvlGrid"
                ItemsSource="{Binding Cvls}" IsReadOnly="True"
                AutoGenerateColumns="False" GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                BorderThickness="0">
        <DataGrid.ContextMenu>
          <ContextMenu>
            <MenuItem Header="Copy CVL id"
                      Command="{Binding CopyCvlIdCommand}"
                      CommandParameter="{Binding #CvlGrid.SelectedItem}" />
          </ContextMenu>
        </DataGrid.ContextMenu>
        <DataGrid.Columns>
          <DataGridTextColumn Binding="{Binding Id}" Width="*" MinWidth="160">
            <DataGridTextColumn.Header><c:FilterableHeader Title="Id" Path="Id" /></DataGridTextColumn.Header>
          </DataGridTextColumn>
          <DataGridTextColumn Binding="{Binding DataType}" Width="120" MinWidth="90">
            <DataGridTextColumn.Header><c:FilterableHeader Title="DataType" Path="DataType" /></DataGridTextColumn.Header>
          </DataGridTextColumn>
          <DataGridTextColumn Binding="{Binding ValueCount}" Width="90" MinWidth="60">
            <DataGridTextColumn.Header><c:FilterableHeader Title="Values" Path="ValueCount" /></DataGridTextColumn.Header>
          </DataGridTextColumn>
          <DataGridTextColumn Binding="{Binding ParentId}" Width="160" MinWidth="100">
            <DataGridTextColumn.Header><c:FilterableHeader Title="Parent" Path="ParentId" /></DataGridTextColumn.Header>
          </DataGridTextColumn>
          <DataGridCheckBoxColumn Binding="{Binding CustomValueList}" Width="80" MinWidth="70">
            <DataGridCheckBoxColumn.Header><c:FilterableHeader Title="Custom" Path="CustomValueList" /></DataGridCheckBoxColumn.Header>
          </DataGridCheckBoxColumn>
        </DataGrid.Columns>
      </DataGrid>
    </Border>

  </c:PageShell>
</UserControl>
