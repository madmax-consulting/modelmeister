<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ModelMeister.Ui.ViewModels"
             xmlns:conv="using:ModelMeister.Ui.Converters"
             xmlns:svc="using:ModelMeister.Ui.Services"
             xmlns:c="using:ModelMeister.Ui.Controls"
             x:Class="ModelMeister.Ui.Views.DiffView"
             x:DataType="vm:DiffViewModel">

  <UserControl.Resources>
    <conv:OperationToBrushConverter x:Key="OpBrush" />
    <conv:KindToOperationConverter x:Key="KindToOp" />
  </UserControl.Resources>

  <c:PageShell Eyebrow="MODEL · COMPARE"
               Subtitle="Diff the loaded model against the connected environment"
               Status="{Binding StatusMessage}"
               IsBusy="{Binding Busy}">

    <DockPanel>

      <!-- Stale-diff banner: the cached diff was invalidated (policy/model/connection changed). -->
      <Border DockPanel.Dock="Top" Margin="0,0,0,8" Padding="12,9" CornerRadius="6"
              Background="{DynamicResource DangerBg}"
              BorderBrush="{DynamicResource Warn}" BorderThickness="1"
              IsVisible="{Binding DiffStale}">
        <Grid ColumnDefinitions="Auto,*,Auto">
          <Path Grid.Column="0" Data="{DynamicResource IcoWarn}" Width="15" Height="15" Stretch="Uniform"
                Stroke="{DynamicResource Warn}" StrokeThickness="1.6" Fill="Transparent"
                VerticalAlignment="Center" Margin="0,0,10,0" />
          <TextBlock Grid.Column="1" VerticalAlignment="Center" TextWrapping="Wrap"
                     Foreground="{DynamicResource TextPri}"
                     Text="The diff is out of date — a policy, model or connection change invalidated it. Run Compare again before applying." />
          <Button Grid.Column="2" Content="Compare" Classes="primary" VerticalAlignment="Center"
                  Margin="10,0,0,0" Command="{Binding CompareCommand}" />
        </Grid>
      </Border>

      <!-- Drift banner: a re-check found the live env changed since this snapshot was captured. -->
      <Border DockPanel.Dock="Top" Margin="0,0,0,8" Padding="12,9" CornerRadius="6"
              Background="{DynamicResource DangerBg}"
              BorderBrush="{DynamicResource Warn}" BorderThickness="1"
              IsVisible="{Binding EnvDrifted}">
        <Grid ColumnDefinitions="Auto,*,Auto">
          <Path Grid.Column="0" Data="{DynamicResource IcoWarn}" Width="15" Height="15" Stretch="Uniform"
                Stroke="{DynamicResource Warn}" StrokeThickness="1.6" Fill="Transparent"
                VerticalAlignment="Center" Margin="0,0,10,0" />
          <TextBlock Grid.Column="1" VerticalAlignment="Center" TextWrapping="Wrap"
                     Foreground="{DynamicResource TextPri}"
                     Text="{Binding EnvDriftSummary}" />
          <Button Grid.Column="2" Content="Compare again" Classes="primary" VerticalAlignment="Center"
                  Margin="10,0,0,0" Command="{Binding CompareCommand}" />
        </Grid>
      </Border>

      <!-- Suppressed-by-policy banner: destructive changes exist but were dropped by the current policy. -->
      <Border DockPanel.Dock="Top" Margin="0,0,0,8" Padding="12,9" CornerRadius="6"
              Background="{DynamicResource DangerBg}"
              BorderBrush="{DynamicResource Warn}" BorderThickness="1"
              IsVisible="{Binding HasSuppressed}">
        <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
          <Path Data="{DynamicResource IcoWarn}" Width="15" Height="15" Stretch="Uniform"
                Stroke="{DynamicResource Warn}" StrokeThickness="1.6" Fill="Transparent"
                VerticalAlignment="Center" />
          <TextBlock VerticalAlignment="Center" TextWrapping="Wrap"
                     Foreground="{DynamicResource TextPri}"
                     Text="{Binding SuppressedSummary}" />
        </StackPanel>
      </Border>

      <Grid ColumnDefinitions="2*,3*">

      <Border Grid.Column="0" Classes="card flush" Padding="0" Margin="0,0,8,0">
        <DockPanel>
          <Border DockPanel.Dock="Top" Padding="14,10" BorderBrush="{DynamicResource Border}" BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="*,Auto,Auto,Auto">
              <TextBlock Grid.Column="0" Text="CHANGE TREE" Classes="h3" VerticalAlignment="Center" />
              <Button Grid.Column="1" Classes="ghost" Command="{Binding RecheckEnvironmentCommand}"
                      ToolTip.Tip="Check whether the environment changed since this snapshot was captured"
                      Margin="0,0,4,0" Padding="8,3">
                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                  <Path Data="{DynamicResource IcoRefresh}" Width="11" Height="11" Stretch="Uniform"
                        Stroke="{DynamicResource TextSec}" StrokeThickness="1.6" Fill="Transparent" />
                  <TextBlock Text="Re-check env" FontSize="11" />
                </StackPanel>
              </Button>
              <Button Grid.Column="2" Classes="ghost icon" Click="OnExpandAllClick"
                      ToolTip.Tip="Expand all" Margin="4,0">
                <Path Data="{DynamicResource IcoChevDown}" Width="11" Height="11" Stretch="Uniform"
                      Stroke="{DynamicResource TextSec}" StrokeThickness="1.7" Fill="Transparent" />
              </Button>
              <Button Grid.Column="3" Classes="ghost icon" Click="OnCollapseAllClick"
                      ToolTip.Tip="Collapse all">
                <Path Data="{DynamicResource IcoChevUp}" Width="11" Height="11" Stretch="Uniform"
                      Stroke="{DynamicResource TextSec}" StrokeThickness="1.7" Fill="Transparent" />
              </Button>
            </Grid>
          </Border>
          <!-- Color legend: maps the tree's pill colors to operations + the danger marker. -->
          <Border DockPanel.Dock="Top" Padding="12,7" BorderBrush="{DynamicResource BorderFaint}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
              <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                <Ellipse Width="7" Height="7" Fill="{DynamicResource DiffAddBrush}" />
                <TextBlock Text="Add" Classes="dim" FontSize="11" />
              </StackPanel>
              <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                <Ellipse Width="7" Height="7" Fill="{DynamicResource DiffUpdateBrush}" />
                <TextBlock Text="Update" Classes="dim" FontSize="11" />
              </StackPanel>
              <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                <Ellipse Width="7" Height="7" Fill="{DynamicResource DiffDeleteBrush}" />
                <TextBlock Text="Delete" Classes="dim" FontSize="11" />
              </StackPanel>
              <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                <Path Data="{DynamicResource IcoWarn}" Width="11" Height="11" Stretch="Uniform"
                      Stroke="{DynamicResource Danger}" StrokeThickness="1.6" Fill="Transparent" />
                <TextBlock Text="Destructive" Classes="dim" FontSize="11" />
              </StackPanel>
            </StackPanel>
          </Border>
          <Border DockPanel.Dock="Top" Padding="10,8" BorderBrush="{DynamicResource BorderFaint}" BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="Auto,*,Auto">
              <Path Grid.Column="0" Data="{DynamicResource IcoSearch}" Width="13" Height="13" Stretch="Uniform"
                    Stroke="{DynamicResource TextDim}" StrokeThickness="1.5" Fill="Transparent"
                    VerticalAlignment="Center" Margin="4,0,8,0" />
              <TextBox Grid.Column="1" Text="{Binding TreeFilter, Mode=TwoWay}"
                       Watermark="Filter changes…" MinHeight="28" />
              <Button Grid.Column="2" Classes="ghost icon" Margin="4,0,0,0"
                      Command="{Binding ClearTreeFilterCommand}"
                      IsVisible="{Binding TreeFilter, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                <Path Data="{DynamicResource IcoX}" Width="10" Height="10" Stretch="Uniform"
                      Stroke="{DynamicResource TextSec}" StrokeThickness="1.7" Fill="Transparent" />
              </Button>
            </Grid>
          </Border>
          <TreeView Name="ChangeTree" ItemsSource="{Binding Tree}" BorderThickness="0"
                    SelectedItem="{Binding SelectedTreeItem, Mode=TwoWay}">
            <TreeView.DataTemplates>
              <TreeDataTemplate ItemsSource="{Binding Operations}" DataType="vm:ConceptNode">
                <TextBlock Text="{Binding Header}" FontWeight="SemiBold" FontSize="13">
                  <TextBlock.ContextMenu>
                    <ContextMenu>
                      <MenuItem Header="Enable all in this concept"
                                Command="{Binding #ChangeTree.((vm:DiffViewModel)DataContext).EnableNodeCommand}"
                                CommandParameter="{Binding}" />
                      <MenuItem Header="Disable all in this concept"
                                Command="{Binding #ChangeTree.((vm:DiffViewModel)DataContext).DisableNodeCommand}"
                                CommandParameter="{Binding}" />
                    </ContextMenu>
                  </TextBlock.ContextMenu>
                </TextBlock>
              </TreeDataTemplate>
              <TreeDataTemplate ItemsSource="{Binding Items}" DataType="vm:OperationNode">
                <Border Classes="pill"
                        Background="Transparent"
                        BorderBrush="{Binding Operation, Converter={StaticResource OpBrush}}"
                        BorderThickness="1"
                        HorizontalAlignment="Left">
                  <Border.ContextMenu>
                    <ContextMenu>
                      <MenuItem Header="Enable all in this group"
                                Command="{Binding #ChangeTree.((vm:DiffViewModel)DataContext).EnableNodeCommand}"
                                CommandParameter="{Binding}" />
                      <MenuItem Header="Disable all in this group"
                                Command="{Binding #ChangeTree.((vm:DiffViewModel)DataContext).DisableNodeCommand}"
                                CommandParameter="{Binding}" />
                    </ContextMenu>
                  </Border.ContextMenu>
                  <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <Ellipse Width="6" Height="6"
                             Fill="{Binding Operation, Converter={StaticResource OpBrush}}" />
                    <TextBlock Text="{Binding Header}"
                               Foreground="{Binding Operation, Converter={StaticResource OpBrush}}" />
                  </StackPanel>
                </Border>
              </TreeDataTemplate>
              <DataTemplate DataType="vm:ChangeRow">
                <Grid ColumnDefinitions="Auto,Auto,*">
                  <Grid.ContextMenu>
                    <ContextMenu>
                      <MenuItem Header="Enable change"
                                Command="{Binding #ChangeTree.((vm:DiffViewModel)DataContext).EnableNodeCommand}"
                                CommandParameter="{Binding}" />
                      <MenuItem Header="Disable change"
                                Command="{Binding #ChangeTree.((vm:DiffViewModel)DataContext).DisableNodeCommand}"
                                CommandParameter="{Binding}" />
                    </ContextMenu>
                  </Grid.ContextMenu>
                  <CheckBox Grid.Column="0" Margin="0,0,8,0"
                            VerticalAlignment="Center"
                            ToolTip.Tip="Include this change in the apply batch"
                            IsChecked="{Binding IsExcluded, Converter={x:Static svc:Eq.BoolNot}, Mode=OneWay}"
                            Click="OnIncludeToggle" />
                  <Path Grid.Column="1" Data="{DynamicResource IcoWarn}" Width="12" Height="12" Stretch="Uniform"
                        Stroke="{DynamicResource Danger}" StrokeThickness="1.6" Fill="Transparent"
                        VerticalAlignment="Center" Margin="0,0,6,0"
                        ToolTip.Tip="Destructive change — deletes data or drops a field. Review before applying."
                        IsVisible="{Binding IsDangerous}" />
                  <TextBlock Grid.Column="2" Text="{Binding Description}"
                             FontSize="12"
                             Foreground="{DynamicResource TextPri}"
                             TextDecorations="{Binding IsExcluded, Converter={x:Static svc:Eq.StrikeIfTrue}}"
                             Opacity="{Binding IsExcluded, Converter={x:Static svc:Eq.OpacityFor}}" />
                </Grid>
              </DataTemplate>
            </TreeView.DataTemplates>
          </TreeView>
        </DockPanel>
      </Border>

      <Grid Grid.Column="1" RowDefinitions="*,Auto,Auto">
        <!-- Details pane -->
        <Border Grid.Row="0" Classes="card flush" Padding="0" Margin="8,0,0,0"
                IsVisible="{Binding HasDetails}">
          <DockPanel>
            <Border DockPanel.Dock="Top" Padding="14,10"
                    BorderBrush="{DynamicResource Border}" BorderThickness="0,0,0,1">
              <StackPanel Spacing="2">
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                  <Ellipse Width="8" Height="8" Fill="{DynamicResource DiffUpdateBrush}" />
                  <TextBlock Text="CHANGE DETAILS" Classes="h3" />
                </StackPanel>
                <TextBlock Text="{Binding SelectedTitle}" FontSize="13" />
                <TextBlock Text="{Binding SelectedSubtitle}" Classes="dim" />
              </StackPanel>
            </Border>
            <Grid>
              <TextBlock Text="No property-level deltas to show for this change."
                         Classes="subtle"
                         Margin="14"
                         IsVisible="{Binding !HasDeltas}" />
              <DataGrid ItemsSource="{Binding SelectedDeltas}" AutoGenerateColumns="False"
                        IsReadOnly="True" BorderThickness="0"
                        IsVisible="{Binding HasDeltas}">
                <DataGrid.Columns>
                  <DataGridTextColumn Width="180" MinWidth="120" Binding="{Binding Property}">
                    <DataGridTextColumn.Header><c:FilterableHeader Title="Property" Path="Property" /></DataGridTextColumn.Header>
                  </DataGridTextColumn>
                  <DataGridTextColumn Width="*" MinWidth="120" Binding="{Binding LiveValue}">
                    <DataGridTextColumn.Header><c:FilterableHeader Title="Live (current)" Path="LiveValue" /></DataGridTextColumn.Header>
                  </DataGridTextColumn>
                  <DataGridTextColumn Width="*" MinWidth="120" Binding="{Binding CodeValue}">
                    <DataGridTextColumn.Header><c:FilterableHeader Title="Code (will become)" Path="CodeValue" /></DataGridTextColumn.Header>
                  </DataGridTextColumn>
                </DataGrid.Columns>
              </DataGrid>
            </Grid>
          </DockPanel>
        </Border>

        <!-- Fallback: full diff text -->
        <Border Grid.Row="0" Classes="card flush" Padding="0" Margin="8,0,0,0"
                IsVisible="{Binding !HasDetails}">
          <DockPanel>
            <Border DockPanel.Dock="Top" Padding="14,10"
                    BorderBrush="{DynamicResource Border}" BorderThickness="0,0,0,1">
              <Grid ColumnDefinitions="*,Auto,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                  <Ellipse Width="8" Height="8" Fill="{DynamicResource Accent}" />
                  <TextBlock Text="DIFF AS TEXT" Classes="h3" />
                  <TextBlock Text="(click an item in the tree to inspect a single change)"
                             Classes="subtle" />
                </StackPanel>
                <Button Grid.Column="1" Classes="ghost icon" Command="{Binding CopyDiffCommand}"
                        ToolTip.Tip="Copy to clipboard" Margin="4,0">
                  <Path Data="{DynamicResource IcoCopy}" Width="13" Height="13" Stretch="Uniform"
                        Stroke="{DynamicResource TextSec}" StrokeThickness="1.5" Fill="Transparent" />
                </Button>
                <Button Grid.Column="2" Classes="ghost icon" Command="{Binding ExportDiffCommand}"
                        ToolTip.Tip="Save as file">
                  <Path Data="{DynamicResource IcoDownload}" Width="13" Height="13" Stretch="Uniform"
                        Stroke="{DynamicResource TextSec}" StrokeThickness="1.5" Fill="Transparent" />
                </Button>
              </Grid>
            </Border>
            <TextBox Text="{Binding DiffText, Mode=OneWay}" IsReadOnly="True"
                     Classes="mono"
                     Background="{DynamicResource DiffTextBackground}"
                     BorderThickness="0"
                     CornerRadius="0"
                     Padding="14"
                     AcceptsReturn="True" TextWrapping="NoWrap"
                     ScrollViewer.HorizontalScrollBarVisibility="Auto"
                     ScrollViewer.VerticalScrollBarVisibility="Auto" />
          </DockPanel>
        </Border>

        <GridSplitter Grid.Row="1" Height="6" Margin="8,4,0,4" Background="Transparent" />

        <Border Grid.Row="2" Classes="card flush" Padding="0" Margin="8,0,0,0" MinHeight="160">
          <DockPanel>
            <Border DockPanel.Dock="Top" Padding="14,10"
                    BorderBrush="{DynamicResource Border}" BorderThickness="0,0,0,1">
              <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Ellipse Width="8" Height="8" Fill="{DynamicResource DiffWarnBrush}" />
                <TextBlock Text="WARNINGS" Classes="h3" />
              </StackPanel>
            </Border>
            <DataGrid ItemsSource="{Binding WarningRows}" AutoGenerateColumns="False"
                      IsReadOnly="True" BorderThickness="0">
              <DataGrid.Columns>
                <DataGridTextColumn Width="80" MinWidth="60" Binding="{Binding Code}">
                  <DataGridTextColumn.Header><c:FilterableHeader Title="Code" Path="Code" /></DataGridTextColumn.Header>
                </DataGridTextColumn>
                <DataGridTextColumn Width="*" MinWidth="160" Binding="{Binding Message}">
                  <DataGridTextColumn.Header><c:FilterableHeader Title="Message" Path="Message" /></DataGridTextColumn.Header>
                </DataGridTextColumn>
              </DataGrid.Columns>
            </DataGrid>
          </DockPanel>
        </Border>
      </Grid>
    </Grid>

    </DockPanel>

  </c:PageShell>
</UserControl>
