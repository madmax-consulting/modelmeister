<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ModelMeister.Ui.ViewModels"
             xmlns:m="using:ModelMeister.Ui.Models"
             xmlns:c="using:ModelMeister.Ui.Controls"
             xmlns:svc="using:ModelMeister.Ui.Services"
             xmlns:conv="using:ModelMeister.Ui.Converters"
             xmlns:views="using:ModelMeister.Ui.Views"
             xmlns:users="using:ModelMeister.Inriver.Users"
             x:Class="ModelMeister.Ui.Views.WorkAreaCompareView"
             x:DataType="vm:WorkAreaCompareViewModel"
             x:Name="Root">

  <UserControl.Resources>
    <conv:StageToBrushConverter x:Key="StageBrush" />
    <conv:StageToTextConverter x:Key="StageText" />
  </UserControl.Resources>

  <views:CompareLayoutView Eyebrow="WORK AREAS · COMPARE"
                           Subtitle="Compare shared folders + saved queries across two environments — promote source → target">
    <views:CompareLayoutView.Body>
      <DockPanel LastChildFill="True">
        <DockPanel DockPanel.Dock="Top" Margin="2,0,0,8">
          <ComboBox DockPanel.Dock="Left" MinWidth="180" Margin="0,0,10,0" IsVisible="{Binding ShowUserPicker}"
                    ItemsSource="{Binding Users}" SelectedItem="{Binding SelectedUser, Mode=TwoWay}"
                    PlaceholderText="Pick a user…" VerticalAlignment="Center">
            <ComboBox.ItemTemplate>
              <DataTemplate x:DataType="users:UserSummary">
                <TextBlock Text="{Binding Username}" />
              </DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>
          <CheckBox DockPanel.Dock="Right" IsChecked="{Binding AllowDeletes, Mode=TwoWay}"
                    VerticalAlignment="Center" Margin="8,0,0,0"
                    ToolTip.Tip="DESTRUCTIVE: when you use Promote all, this also DELETES folders that exist only in the target so it becomes an exact mirror of the source. Per-row and 'Promote selected' never delete.">
            <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
              <Path Data="{DynamicResource IcoWarn}" Width="12" Height="12" Stretch="Uniform"
                    Stroke="{DynamicResource Danger}" StrokeThickness="1.6" Fill="Transparent"
                    VerticalAlignment="Center"
                    IsVisible="{Binding AllowDeletes}" />
              <TextBlock Text="Promote all DELETES target-only folders" FontSize="12"
                         Foreground="{DynamicResource Danger}" VerticalAlignment="Center" />
            </StackPanel>
          </CheckBox>
          <c:GridToolbar TargetGrid="{Binding #MainGrid}" />
        </DockPanel>
        <DataGrid Name="MainGrid" ItemsSource="{Binding Rows}" IsReadOnly="True"
                  AutoGenerateColumns="False" GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                  SelectionMode="Extended" svc:GridSelectionBehavior.Selection="{Binding Selection}"
                  Classes="filterable fit">
          <DataGrid.Columns>
            <DataGridTemplateColumn Width="40" CanUserResize="False" CanUserReorder="False" CanUserSort="False"
                                    CellTemplate="{StaticResource RowSelectCell}">
              <DataGridTemplateColumn.Header>
                <CheckBox IsChecked="{Binding #Root.((vm:WorkAreaCompareViewModel)DataContext).Selection.AllSelected, Mode=TwoWay}"
                          ToolTip.Tip="Select all" />
              </DataGridTemplateColumn.Header>
            </DataGridTemplateColumn>

            <!-- Which environment(s) the folder exists in, as named stage pills (no left/right wording). -->
            <DataGridTemplateColumn Header="Environment" Width="170" MinWidth="130">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate x:DataType="vm:WorkAreaDiffRow">
                  <StackPanel Orientation="Horizontal" Spacing="3" VerticalAlignment="Center">
                    <Border Classes="pill" IsVisible="{Binding LeftPresent}"
                            Background="{Binding $parent[DataGrid].((vm:WorkAreaCompareViewModel)DataContext).LeftColumnStage, Converter={StaticResource StageBrush}, ConverterParameter=soft}"
                            BorderBrush="{Binding $parent[DataGrid].((vm:WorkAreaCompareViewModel)DataContext).LeftColumnStage, Converter={StaticResource StageBrush}}"
                            BorderThickness="1" Padding="7,0">
                      <TextBlock Text="{Binding $parent[DataGrid].((vm:WorkAreaCompareViewModel)DataContext).LeftColumnHeader}"
                                 Foreground="{Binding $parent[DataGrid].((vm:WorkAreaCompareViewModel)DataContext).LeftColumnStage, Converter={StaticResource StageBrush}}"
                                 FontSize="10" FontWeight="SemiBold" />
                    </Border>
                    <Border Classes="pill" IsVisible="{Binding RightPresent}"
                            Background="{Binding $parent[DataGrid].((vm:WorkAreaCompareViewModel)DataContext).RightColumnStage, Converter={StaticResource StageBrush}, ConverterParameter=soft}"
                            BorderBrush="{Binding $parent[DataGrid].((vm:WorkAreaCompareViewModel)DataContext).RightColumnStage, Converter={StaticResource StageBrush}}"
                            BorderThickness="1" Padding="7,0">
                      <TextBlock Text="{Binding $parent[DataGrid].((vm:WorkAreaCompareViewModel)DataContext).RightColumnHeader}"
                                 Foreground="{Binding $parent[DataGrid].((vm:WorkAreaCompareViewModel)DataContext).RightColumnStage, Converter={StaticResource StageBrush}}"
                                 FontSize="10" FontWeight="SemiBold" />
                    </Border>
                  </StackPanel>
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>

            <DataGridTextColumn Binding="{Binding Path}" Width="2*" MinWidth="160">
              <DataGridTextColumn.Header><c:FilterableHeader Title="Path" Path="Path" /></DataGridTextColumn.Header>
            </DataGridTextColumn>
            <DataGridTextColumn Binding="{Binding Kind}" Width="110" MinWidth="90">
              <DataGridTextColumn.Header><c:FilterableHeader Title="Kind" Path="Kind" /></DataGridTextColumn.Header>
            </DataGridTextColumn>

            <!-- Difference + an advisory warning when the source query references ids missing from the target. -->
            <DataGridTemplateColumn Width="1.8*" MinWidth="160">
              <DataGridTemplateColumn.Header><c:FilterableHeader Title="Difference" Path="Detail" /></DataGridTemplateColumn.Header>
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate x:DataType="vm:WorkAreaDiffRow">
                  <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <Path Data="{DynamicResource IcoWarn}" Width="13" Height="13" Stretch="Uniform"
                          Stroke="{DynamicResource Warn}" StrokeThickness="1.6" Fill="Transparent"
                          VerticalAlignment="Center" IsVisible="{Binding HasValidityWarning}"
                          ToolTip.Tip="{Binding ValidityWarning}" />
                    <TextBlock Text="{Binding Detail}" VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis" ToolTip.Tip="{Binding Detail}" />
                  </StackPanel>
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>

            <!-- Per-row promote (one-way: source → target). Hidden on target-only rows (would be a delete). -->
            <DataGridTemplateColumn Header="Promote" Width="150" MinWidth="140">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate x:DataType="vm:WorkAreaDiffRow">
                  <Button Classes="ghost" Padding="4,2" Margin="4,0"
                          IsVisible="{Binding CanPromoteLeftToRight}"
                          ToolTip.Tip="Promote this folder (and its parents) from the source environment into the target one"
                          Command="{Binding $parent[DataGrid].((vm:WorkAreaCompareViewModel)DataContext).ApplyCommand}"
                          CommandParameter="{Binding}">
                    <StackPanel Orientation="Horizontal" Spacing="3" VerticalAlignment="Center">
                      <Border Classes="pill"
                              Background="{Binding $parent[DataGrid].((vm:WorkAreaCompareViewModel)DataContext).LeftColumnStage, Converter={StaticResource StageBrush}, ConverterParameter=soft}"
                              BorderBrush="{Binding $parent[DataGrid].((vm:WorkAreaCompareViewModel)DataContext).LeftColumnStage, Converter={StaticResource StageBrush}}"
                              BorderThickness="1" Padding="4,0">
                        <TextBlock Text="{Binding $parent[DataGrid].((vm:WorkAreaCompareViewModel)DataContext).LeftColumnStage, Converter={StaticResource StageText}}"
                                   Foreground="{Binding $parent[DataGrid].((vm:WorkAreaCompareViewModel)DataContext).LeftColumnStage, Converter={StaticResource StageBrush}}"
                                   FontSize="9" FontWeight="SemiBold" />
                      </Border>
                      <TextBlock Text="→" VerticalAlignment="Center" />
                      <Border Classes="pill"
                              Background="{Binding $parent[DataGrid].((vm:WorkAreaCompareViewModel)DataContext).RightColumnStage, Converter={StaticResource StageBrush}, ConverterParameter=soft}"
                              BorderBrush="{Binding $parent[DataGrid].((vm:WorkAreaCompareViewModel)DataContext).RightColumnStage, Converter={StaticResource StageBrush}}"
                              BorderThickness="1" Padding="4,0">
                        <TextBlock Text="{Binding $parent[DataGrid].((vm:WorkAreaCompareViewModel)DataContext).RightColumnStage, Converter={StaticResource StageText}}"
                                   Foreground="{Binding $parent[DataGrid].((vm:WorkAreaCompareViewModel)DataContext).RightColumnStage, Converter={StaticResource StageBrush}}"
                                   FontSize="9" FontWeight="SemiBold" />
                      </Border>
                    </StackPanel>
                  </Button>
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>
          </DataGrid.Columns>
        </DataGrid>
      </DockPanel>
    </views:CompareLayoutView.Body>
  </views:CompareLayoutView>
</UserControl>
