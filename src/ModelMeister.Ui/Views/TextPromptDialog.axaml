<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ModelMeister.Ui.ViewModels"
        x:Class="ModelMeister.Ui.Views.TextPromptDialog"
        x:DataType="vm:TextPromptViewModel"
        Title="{Binding Title}"
        Width="460" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="{DynamicResource Surface0}"
        FontFamily="{StaticResource UiFont}">

  <Border Padding="0" Background="{DynamicResource AppBackground}">
    <StackPanel Margin="28,24,28,22" Spacing="14">

      <TextBlock Text="{Binding Title}" FontSize="18" FontWeight="Bold" />

      <StackPanel Spacing="4">
        <TextBlock Text="{Binding Label}" Classes="label" />
        <TextBox Name="Input" Text="{Binding Text, Mode=TwoWay}"
                 Watermark="{Binding Watermark}" />
      </StackPanel>

      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,4,0,0">
        <Button Content="Cancel" Command="{Binding CancelCommand}" IsCancel="True" />
        <Button Content="{Binding ConfirmLabel}" Command="{Binding ConfirmCommand}"
                Classes="primary" IsDefault="True" />
      </StackPanel>
    </StackPanel>
  </Border>
</Window>
