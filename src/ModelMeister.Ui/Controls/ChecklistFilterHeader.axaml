<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:c="using:ModelMeister.Ui.Controls"
             x:Class="ModelMeister.Ui.Controls.ChecklistFilterHeader"
             x:Name="Root"
             ClipToBounds="True">

  <!-- Same structural shape as FilterableHeader: a single Grid that fills the column header rect,
       with title on top and the filter row underneath. Checklist flyout button overlays the right
       edge of the textbox so widths don't shift when the indicator dot appears. -->
  <Grid RowDefinitions="Auto,*" Background="Transparent">

    <TextBlock Grid.Row="0"
               Text="{Binding #Root.Title}"
               FontWeight="SemiBold" FontSize="11"
               Foreground="{DynamicResource TextSec}"
               TextTrimming="CharacterEllipsis"
               ToolTip.Tip="{Binding #Root.Title}"
               Margin="10,6,10,2"
               VerticalAlignment="Center" />

    <Grid Grid.Row="1" Margin="6,0,6,6">
      <TextBox Text="{Binding #Root.FilterText, Mode=TwoWay}"
               Watermark="Filter…"
               FontSize="11"
               MinHeight="22"
               Padding="6,2,30,2"
               HorizontalAlignment="Stretch"
               VerticalAlignment="Stretch" />

      <Button Classes="ghost" Padding="4,0" MinHeight="20" MinWidth="22"
              HorizontalAlignment="Right" VerticalAlignment="Center"
              Margin="0,0,2,0"
              ToolTip.Tip="Checkbox filter"
              Click="OnFilterButtonClick">
        <StackPanel Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">
          <TextBlock Text="▾" FontSize="9" />
          <Ellipse Width="6" Height="6" Fill="{DynamicResource Accent}"
                   IsVisible="{Binding #Root.HasActiveFilter}" />
        </StackPanel>
        <Button.Flyout>
          <Flyout Placement="Bottom">
            <Border Width="260" Padding="6">
              <DockPanel LastChildFill="True">
                <TextBox DockPanel.Dock="Top" Text="{Binding #Root.Search, Mode=TwoWay}"
                         Watermark="Search…" Margin="0,0,0,4" />
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="6" Margin="0,0,0,4">
                  <Button Content="Select all" Classes="ghost" Padding="6,2" Click="OnSelectAll" />
                  <Button Content="Clear" Classes="ghost" Padding="6,2" Click="OnClearAll" />
                </StackPanel>
                <TextBlock DockPanel.Dock="Top" Classes="dim" FontSize="11"
                           Text="(nothing to filter — run Compare first)"
                           IsVisible="{Binding #Root.IsEmpty}" Margin="0,4" />
                <ScrollViewer MaxHeight="260">
                  <ItemsControl ItemsSource="{Binding #Root.FilteredOptions}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate x:DataType="c:FilterOption">
                        <CheckBox Content="{Binding Value}"
                                  IsChecked="{Binding IsChecked, Mode=TwoWay}" />
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </ScrollViewer>
              </DockPanel>
            </Border>
          </Flyout>
        </Button.Flyout>
      </Button>
    </Grid>
  </Grid>
</UserControl>
